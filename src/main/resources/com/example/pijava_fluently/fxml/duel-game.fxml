<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.DuelGameController"
      spacing="0"
      style="-fx-background-color:#F0F2FF;">

    <!-- ══ EN-TÊTE TITRE + TIMER ══ -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white;-fx-padding:18 30;
                 -fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">
        <Label fx:id="labelTitre" text="⚔️ Duel"
               style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="labelProgression" text="Question 1/5"
               style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>
        <Label fx:id="labelTimer" text="⏱ 15s"
               style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#EF4444;
                      -fx-background-color:#FEF2F2;-fx-background-radius:20;
                      -fx-padding:6 14;"/>
    </HBox>

    <!-- ══ SCORES ══ -->
    <HBox spacing="0"
          style="-fx-background-color:white;-fx-padding:16 30;
                 -fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">

        <!-- Moi -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="6">
            <Label fx:id="labelNomMoi" text="🏆 Moi"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
            <ProgressBar fx:id="barMoi" progress="0"
                         prefWidth="200" prefHeight="10"
                         style="-fx-accent:#6C63FF;"/>
            <Label fx:id="labelScoreMoi" text="0 pts"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
        </VBox>

        <!-- VS -->
        <VBox alignment="CENTER" prefWidth="60">
            <Label text="VS"
                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#C0C7D0;"/>
        </VBox>

        <!-- Adversaire -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" spacing="6">
            <Label fx:id="labelNomAdv" text="⚔️ Adversaire"
                   style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#EC4899;"/>
            <ProgressBar fx:id="barAdv" progress="0"
                         prefWidth="200" prefHeight="10"
                         style="-fx-accent:#EC4899;"/>
            <Label fx:id="labelScoreAdv" text="0 pts"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#EC4899;"/>
        </VBox>
    </HBox>

    <!-- ══ QUESTION ══ -->
    <VBox VBox.vgrow="ALWAYS" spacing="20"
          style="-fx-padding:30 40;">

        <!-- Énoncé -->
        <Label fx:id="labelQuestion" text=""
               wrapText="true"
               style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;
                      -fx-background-color:white;-fx-background-radius:14;
                      -fx-padding:20 24;
                      -fx-border-color:#E8EAF0;-fx-border-radius:14;-fx-border-width:1;"/>

        <!-- Réponses -->
        <VBox fx:id="vboxReponses" spacing="12"/>

        <!-- Panel résultat (caché pendant le jeu) -->
        <VBox fx:id="panelResultat" visible="false" managed="false"
              spacing="20" alignment="CENTER"
              style="-fx-background-color:white;-fx-background-radius:18;
                     -fx-padding:40;
                     -fx-border-color:#E8EAF0;-fx-border-radius:18;-fx-border-width:1;">

            <Label text="🎮 Duel terminé !"
                   style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>

            <Label fx:id="labelGagnant" text=""
                   style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>

            <!-- Scores finaux répétés ici -->
            <HBox spacing="60" alignment="CENTER">
                <VBox alignment="CENTER" spacing="6">
                    <Label text="Mon score"
                           style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>
                    <Label fx:id="labelScoreFinMoi" text="0 pts"
                           style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
                </VBox>
                <VBox alignment="CENTER" spacing="6">
                    <Label text="Score adversaire"
                           style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>
                    <Label fx:id="labelScoreFinAdv" text="0 pts"
                           style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#EC4899;"/>
                </VBox>
            </HBox>

            <Button text="🏠 Retour à l'accueil"
                    onAction="#handleRetour"
                    style="-fx-background-color:#6C63FF;-fx-text-fill:white;
                           -fx-font-weight:bold;-fx-background-radius:12;
                           -fx-font-size:14px;-fx-padding:12 28;-fx-cursor:hand;"/>
        </VBox>
    </VBox>
</VBox>