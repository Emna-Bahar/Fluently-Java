<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            style="-fx-background:#F1F5F9;-fx-background-color:#F1F5F9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.Sessionprofcontroller">

    <VBox fx:id="rootPane" spacing="24"
          style="-fx-padding:30 36 30 36;-fx-background-color:#F1F5F9;">

        <!-- ══ En-tête ══ -->
        <HBox alignment="CENTER_LEFT"
              style="-fx-background-color:linear-gradient(from 0% 0% to 100% 0%,#3B82F6,#6C63FF);
                     -fx-background-radius:18;-fx-padding:28 32 28 32;
                     -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.40),24,0,0,8);">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="📅  Gestion des Sessions"
                       style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label text="Créez, modifiez et gérez les réservations de vos sessions"
                       style="-fx-font-size:13px;-fx-text-fill:#BFC8D9;"/>
            </VBox>
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Label fx:id="countLabel" text="0 session(s)"
                       style="-fx-background-color:#FFFFFF33;-fx-text-fill:white;
                              -fx-font-size:13px;-fx-font-weight:bold;
                              -fx-background-radius:30;-fx-padding:8 18 8 18;"/>
            </HBox>
        </HBox>

        <!-- ══ Barre outils ══ -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="380"
                  style="-fx-background-color:#FFFFFF;-fx-background-radius:12;
                         -fx-border-color:#E2E8F0;-fx-border-radius:12;-fx-border-width:1.5;
                         -fx-padding:10 16 10 16;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                <Label text="🔍" style="-fx-font-size:14px;-fx-text-fill:#9CA3AF;"/>
                <TextField fx:id="searchField" promptText="Rechercher…"
                           onKeyReleased="#handleSearch" HBox.hgrow="ALWAYS"
                           style="-fx-background-color:transparent;-fx-border-color:transparent;
                                  -fx-font-size:13px;-fx-text-fill:#374151;"/>
            </HBox>
            <ComboBox fx:id="filterStatut" prefWidth="160"
                      style="-fx-background-color:#FFFFFF;-fx-border-color:#E2E8F0;
                             -fx-border-radius:12;-fx-background-radius:12;
                             -fx-border-width:1.5;-fx-font-size:13px;-fx-padding:8;"/>
            <Button text="✚  Nouvelle Session" onAction="#handleAjouter"
                    style="-fx-background-color:linear-gradient(from 0% 0% to 100% 0%,#3B82F6,#6C63FF);
                           -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                           -fx-background-radius:12;-fx-padding:12 22 12 22;-fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),12,0,0,4);"/>
        </HBox>

        <!-- ══ Formulaire ══ -->
        <VBox fx:id="formCard" spacing="16" visible="false" managed="false"
              style="-fx-background-color:#FFFFFF;-fx-background-radius:20;
                     -fx-border-color:#E2E8F0;-fx-border-radius:20;-fx-border-width:1.5;
                     -fx-padding:28;
                     -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.12),24,0,0,8);">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="formTitleIcon" text="✚"
                       style="-fx-font-size:22px;-fx-text-fill:#3B82F6;"/>
                <Label fx:id="formTitle" text="Nouvelle Session"
                       style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            </HBox>

            <!-- Bandeau : tous les champs sont obligatoires -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color:#EEF2FF;-fx-background-radius:10;
                         -fx-border-color:#C7D2FE;-fx-border-radius:10;-fx-border-width:1;
                         -fx-padding:10 14 10 14;">
                <Label text="ℹ️" style="-fx-font-size:14px;"/>
                <Label text="Tous les champs sont obligatoires. La date doit être dans le futur."
                       style="-fx-font-size:12px;-fx-text-fill:#3730A3;-fx-font-weight:bold;"/>
            </HBox>

            <Separator/>

            <!-- Ligne 1 : Date + Heure + Statut -->
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="📅  Date * (obligatoire — doit être dans le futur)"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <DatePicker fx:id="fieldDate" maxWidth="Infinity"
                                style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                       -fx-border-radius:10;-fx-background-radius:10;-fx-border-width:1.5;"/>
                    <Label fx:id="errDate" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" prefWidth="150">
                    <Label text="⏰  Heure * (HH:mm)"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldHeure" promptText="Ex : 14:30"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-border-width:1.5;-fx-padding:11 14 11 14;-fx-font-size:13px;"/>
                    <Label fx:id="errHeure" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" prefWidth="190">
                    <Label text="📌  Statut *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboStatut" maxWidth="Infinity" promptText="Choisir…"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;
                                     -fx-border-width:1.5;-fx-font-size:13px;"/>
                    <Label fx:id="errStatut" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <!-- Ligne 2 : Groupe + Lien réunion -->
            <HBox spacing="16">
                <VBox spacing="4" prefWidth="230">
                    <Label text="👥  Groupe *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboGroupe" maxWidth="Infinity" promptText="Sélectionner…"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;
                                     -fx-border-width:1.5;-fx-font-size:13px;"/>
                    <Label fx:id="errGroupe" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="🔗  Lien réunion * (https://…)"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldLien" promptText="https://meet.google.com/…"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-border-width:1.5;-fx-padding:11 14 11 14;-fx-font-size:13px;"/>
                    <Label fx:id="errLien" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <!-- Ligne 3 : Durée + Prix + Capacité -->
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="⏱  Durée * (minutes)"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldDuree" promptText="Ex : 90"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-border-width:1.5;-fx-padding:11 14 11 14;-fx-font-size:13px;"/>
                    <Label fx:id="errDuree" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="💰  Prix TND *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldPrix" promptText="Ex : 50"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-border-width:1.5;-fx-padding:11 14 11 14;-fx-font-size:13px;"/>
                    <Label fx:id="errPrix" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="🪑  Capacité max *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldCapacite" promptText="Ex : 15"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-border-width:1.5;-fx-padding:11 14 11 14;-fx-font-size:13px;"/>
                    <Label fx:id="errCapacite" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <!-- Description -->
            <VBox spacing="4">
                <Label text="📝  Description *"
                       style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                <TextArea fx:id="fieldDescription" promptText="Décrivez la session (objectifs, contenu, niveau requis…)"
                          prefRowCount="3" wrapText="true"
                          style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                 -fx-border-radius:10;-fx-background-radius:10;
                                 -fx-border-width:1.5;-fx-padding:11 14 11 14;-fx-font-size:13px;"/>
                <Label fx:id="errDescription" text="" visible="false" managed="false"
                       style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
            </VBox>

            <!-- Boutons -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="✕  Annuler" onAction="#handleCancel"
                        style="-fx-background-color:#F8FAFC;-fx-text-fill:#64748B;-fx-font-size:13px;
                               -fx-font-weight:bold;-fx-background-radius:10;-fx-padding:11 22 11 22;
                               -fx-cursor:hand;-fx-border-color:#E2E8F0;-fx-border-width:1.5;-fx-border-radius:10;"/>
                <Button text="💾  Enregistrer" onAction="#handleSave"
                        style="-fx-background-color:linear-gradient(from 0% 0% to 100% 0%,#3B82F6,#6C63FF);
                               -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                               -fx-background-radius:10;-fx-padding:11 22 11 22;-fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),10,0,0,3);"/>
            </HBox>
        </VBox>

        <!-- ══ Grille de cartes ══ -->
        <FlowPane fx:id="cardsContainer" hgap="20" vgap="20"
                  style="-fx-background-color:transparent;" prefWrapLength="920"/>

    </VBox>
</ScrollPane>
