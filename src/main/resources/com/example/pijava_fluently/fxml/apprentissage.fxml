<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.ApprentissageController"
      spacing="0" style="-fx-background-color:#F8F9FD;">

    <!-- Header avec retour -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white;-fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">
        <padding><Insets top="16" left="32" right="32" bottom="16"/></padding>
        <Button text="← Retour" style="-fx-background-color:#F1F5F9;-fx-text-fill:#4A4D6A;-fx-font-size:13px;-fx-background-radius:10;-fx-padding:8 16 8 16;-fx-cursor:hand;" onAction="#handleRetour"/>
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label fx:id="langueNom" text="Français" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <Label fx:id="langueDescription" text="Langue de Molière" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
        </VBox>
        <VBox alignment="CENTER_RIGHT" spacing="2">
            <Label text="Niveau actuel" style="-fx-font-size:11px;-fx-text-fill:#8A8FA8;"/>
            <Label fx:id="niveauActuelValue" text="Non défini" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;">
        <VBox spacing="30">
            <padding><Insets top="30" left="40" right="40" bottom="40"/></padding>

            <!-- Test de niveau (optionnel) -->
            <VBox spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),12,0,0,4);-fx-padding:20;">
                <Label text="📝 Évaluez votre niveau" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                <Label text="Passez notre test de niveau pour un parcours personnalisé" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                <Button text="Commencer le test →" style="-fx-background-color:#6C63FF;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:10;-fx-padding:10 20 10 20;-fx-cursor:hand;-fx-max-width:200;" onAction="#handleTest"/>
            </VBox>

            <!-- Niveaux d'apprentissage -->
            <VBox spacing="16">
                <Label text="🎯 Parcours d'apprentissage" style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                <Label text="Progressez niveau par niveau avec nos cours interactifs" style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>

                <!-- Niveau A1 -->
                <VBox fx:id="niveauA1" spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="A1" style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Débutant" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label text="Les bases de la langue" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                        <Label fx:id="progressA1" text="0/3 cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                    </HBox>
                    <!-- Cercles des cours -->
                    <HBox fx:id="coursA1" spacing="15" alignment="CENTER"/>
                </VBox>

                <!-- Niveau A2 -->
                <VBox fx:id="niveauA2" spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="A2" style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#8B5CF6;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Élémentaire" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label text="Communication simple" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                        <Label fx:id="progressA2" text="0/3 cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                    </HBox>
                    <HBox fx:id="coursA2" spacing="15" alignment="CENTER"/>
                </VBox>

                <!-- Niveau B1 -->
                <VBox fx:id="niveauB1" spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="B1" style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#F59E0B;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Intermédiaire" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label text="Compréhension de sujets familiers" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                        <Label fx:id="progressB1" text="0/3 cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                    </HBox>
                    <HBox fx:id="coursB1" spacing="15" alignment="CENTER"/>
                </VBox>

                <!-- Niveau B2 -->
                <VBox fx:id="niveauB2" spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="B2" style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#EF4444;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Intermédiaire supérieur" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label text="Interaction fluide" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                        <Label fx:id="progressB2" text="0/3 cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                    </HBox>
                    <HBox fx:id="coursB2" spacing="15" alignment="CENTER"/>
                </VBox>

                <!-- Niveau C1 -->
                <VBox fx:id="niveauC1" spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="C1" style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#EC4899;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Avancé" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label text="Expression spontanée" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                        <Label fx:id="progressC1" text="0/3 cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                    </HBox>
                    <HBox fx:id="coursC1" spacing="15" alignment="CENTER"/>
                </VBox>

                <!-- Niveau C2 -->
                <VBox fx:id="niveauC2" spacing="12" style="-fx-background-color:white;-fx-background-radius:20;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),8,0,0,2);-fx-padding:20;">
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label text="C2" style="-fx-font-size:28px;-fx-font-weight:bold;-fx-text-fill:#14B8A6;"/>
                        <VBox HBox.hgrow="ALWAYS">
                            <Label text="Maîtrise" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label text="Compréhension quasi complète" style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                        <Label fx:id="progressC2" text="0/3 cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                    </HBox>
                    <HBox fx:id="coursC2" spacing="15" alignment="CENTER"/>
                </VBox>
            </VBox>
        </VBox>
    </ScrollPane>

    <!-- Dialogue de ressources -->
    <DialogPane fx:id="ressourcesDialog" visible="false" managed="false"/>
</VBox>