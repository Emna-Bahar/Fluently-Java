<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.collections.FXCollections?>


<?import java.lang.String?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.ApprentissageController"
      spacing="0" style="-fx-background-color: linear-gradient(to bottom, #F0F4FF, #FAFBFF);">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: linear-gradient(to right, #6C63FF, #8B5CF6); -fx-effect: dropshadow(gaussian, rgba(108,99,255,0.2), 10, 0, 0, 2);">
        <padding><Insets top="20" left="32" right="32" bottom="20"/></padding>
        <Button text="← Retour"
                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"
                onAction="#handleRetour"/>
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label fx:id="langueNom" text="Français" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="langueDescription" text="Langue de Molière" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
        <VBox alignment="CENTER_RIGHT" spacing="4"
              style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 16; -fx-padding: 8 16 8 16;">
            <Label text="Niveau actuel" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7);"/>
            <Label fx:id="niveauActuelValue" text="Non défini" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="24">
            <padding><Insets top="30" left="40" right="40" bottom="40"/></padding>

            <!-- SECTION 1 : TEST DE NIVEAU -->
            <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 4); -fx-padding: 24;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #F0E6FF; -fx-background-radius: 30;">
                        <Label text="📝" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Évaluez votre niveau" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Passez notre test de niveau pour un parcours personnalisé" style="-fx-font-size: 13px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Button text="Commencer le test →"
                            style="-fx-background-color: #6C63FF; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24 12 24; -fx-cursor: hand;"
                            onAction="#handleTest"/>
                </HBox>
            </VBox>

            <!-- SECTION 2 : GÉNÉRATION DE COURS (VIOLET) -->
            <VBox spacing="16" style="-fx-background-color: #667eea; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 24;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30;">
                        <Label text="✨" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Générer un cours personnalisé" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Créez un cours sur mesure selon vos besoins" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                    <Button fx:id="btnOuvrirFormCours" text="Créer mon cours →"
                            style="-fx-background-color: white; -fx-text-fill: #667eea; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24 12 24; -fx-cursor: hand;"
                            onAction="#ouvrirFormulaireCours"/>
                </HBox>
            </VBox>

            <!-- Formulaire (caché par défaut) -->
            <VBox fx:id="formCoursContainer" spacing="20" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5); -fx-padding: 28;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <StackPane style="-fx-background-color: #F0E6FF; -fx-background-radius: 30;">
                        <Label text="📖" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Personnalisez votre cours" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Remplissez les champs ci-dessous pour générer un cours adapté" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Button text="✕ Fermer" style="-fx-background-color: #F4F5FA; -fx-text-fill: #4A4D6A; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 16 8 16; -fx-cursor: hand;"
                            onAction="#fermerFormulaireCours"/>
                </HBox>
                <Separator style="-fx-background-color: #E0E3F0;"/>
                <GridPane hgap="25" vgap="20">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="25"/>
                        <ColumnConstraints percentWidth="75"/>
                    </columnConstraints>
                    <Label text="🎯 Thème du cours :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4A4D6A;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="fieldTheme" promptText="Ex: Voyage, Affaires, Cuisine..." style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #E0E3F0; -fx-border-radius: 12; -fx-padding: 12 15;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="📚 Point de grammaire :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4A4D6A;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="fieldGrammaire" promptText="Ex: Passé composé, Subjonctif..." style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #E0E3F0; -fx-border-radius: 12; -fx-padding: 12 15;" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="📝 Vocabulaire :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4A4D6A;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="fieldVocabulaire" promptText="Optionnel" style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #E0E3F0; -fx-border-radius: 12; -fx-padding: 12 15;" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>
                <VBox spacing="12">
                    <Label text="⭐ Sélectionnez votre niveau :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4A4D6A;"/>
                    <HBox spacing="20" alignment="CENTER">
                        <VBox alignment="CENTER" spacing="5" fx:id="niveauA1Btn" onMouseClicked="#selectionnerNiveauA1" style="-fx-cursor: hand;">
                            <StackPane style="-fx-background-color: #6C63FF; -fx-background-radius: 40; -fx-padding: 15;"><Label text="A1" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/></StackPane>
                            <Label text="Débutant" style="-fx-font-size: 10px; -fx-text-fill: #6C63FF;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5" fx:id="niveauA2Btn" onMouseClicked="#selectionnerNiveauA2" style="-fx-cursor: hand;">
                            <StackPane style="-fx-background-color: #8B5CF6; -fx-background-radius: 40; -fx-padding: 15;"><Label text="A2" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/></StackPane>
                            <Label text="Élémentaire" style="-fx-font-size: 10px; -fx-text-fill: #8B5CF6;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5" fx:id="niveauB1Btn" onMouseClicked="#selectionnerNiveauB1" style="-fx-cursor: hand;">
                            <StackPane style="-fx-background-color: #F59E0B; -fx-background-radius: 40; -fx-padding: 15;"><Label text="B1" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/></StackPane>
                            <Label text="Intermédiaire" style="-fx-font-size: 10px; -fx-text-fill: #F59E0B;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5" fx:id="niveauB2Btn" onMouseClicked="#selectionnerNiveauB2" style="-fx-cursor: hand;">
                            <StackPane style="-fx-background-color: #EF4444; -fx-background-radius: 40; -fx-padding: 15;"><Label text="B2" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/></StackPane>
                            <Label text="Avancé" style="-fx-font-size: 10px; -fx-text-fill: #EF4444;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5" fx:id="niveauC1Btn" onMouseClicked="#selectionnerNiveauC1" style="-fx-cursor: hand;">
                            <StackPane style="-fx-background-color: #EC4899; -fx-background-radius: 40; -fx-padding: 15;"><Label text="C1" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/></StackPane>
                            <Label text="Autonome" style="-fx-font-size: 10px; -fx-text-fill: #EC4899;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="5" fx:id="niveauC2Btn" onMouseClicked="#selectionnerNiveauC2" style="-fx-cursor: hand;">
                            <StackPane style="-fx-background-color: #14B8A6; -fx-background-radius: 40; -fx-padding: 15;"><Label text="C2" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/></StackPane>
                            <Label text="Maîtrise" style="-fx-font-size: 10px; -fx-text-fill: #14B8A6;"/>
                        </VBox>
                    </HBox>
                    <Label fx:id="niveauSelectionneLabel" text="Niveau sélectionné : Aucun" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                </VBox>
                <VBox spacing="10">
                    <Label text="📄 Aperçu :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #4A4D6A;"/>
                    <TextArea fx:id="apercuCours" editable="false" wrapText="true" prefHeight="150" promptText="Votre cours apparaîtra ici..." style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #E0E3F0; -fx-border-radius: 12; -fx-font-size: 12px;"/>
                </VBox>
                <HBox fx:id="loadingContainer" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator fx:id="loadingIA" prefWidth="40" prefHeight="40"/>
                    <Label fx:id="loadingText" text="🤖 Génération en cours..." style="-fx-font-size: 13px; -fx-text-fill: #6C63FF; -fx-font-weight: bold;"/>
                </HBox>
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="🗑️ Effacer" style="-fx-background-color: #F4F5FA; -fx-text-fill: #4A4D6A; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 20;" onAction="#effacerFormulaire"/>
                    <Button text="🔄 Générer" style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 24;" onAction="#genererCours"/>
                    <Button fx:id="btnExporterPDF" text="📥 Exporter PDF" disable="true" style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 10 24;" onAction="#exporterPDF"/>
                </HBox>
            </VBox>

            <!-- SECTION 3 : DICTIONNAIRE AVEC IA (BLEU TURQUOISE) -->
            <VBox spacing="16" style="-fx-background-color: #1E88B0; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 24;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30;">
                        <Label text="📖" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Dictionnaire avec IA" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Trouvez la définition, traduction et exemples d'un mot" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="dictionarySearchField" promptText="Entrez un mot à définir..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: transparent; -fx-padding: 12 15; -fx-font-size: 13px;"/>
                    <Button text="🔍 Chercher" onAction="#chercherMotDictionnaire"
                            style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
                </HBox>
                <HBox fx:id="dictionaryLoading" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator prefWidth="30" prefHeight="30"/>
                    <Label text="Recherche en cours..." style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </HBox>
                <VBox fx:id="dictionaryResultContainer" spacing="12" visible="false" managed="false"
                      style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 16; -fx-padding: 16;">
                    <Label fx:id="dictionaryWord" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <Label fx:id="dictionaryDefinition" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.9);"/>
                    <Label fx:id="dictionaryExample" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7); -fx-font-style: italic;"/>
                    <Label fx:id="dictionarySynonym" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                </VBox>
                <VBox fx:id="dictionaryEmptyMessage" alignment="CENTER" spacing="10" visible="false" managed="false">
                    <Label text="📭" style="-fx-font-size: 32px;"/>
                    <Label text="Aucun résultat" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </VBox>
            </VBox>

            <!-- SECTION 4 : RECHERCHE YOUTUBE (ROUGE) -->
            <VBox spacing="16" style="-fx-background-color: #DC2626; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 24;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30;">
                        <Label text="🎬" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Rechercher des vidéos YouTube" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Trouvez des vidéos pour améliorer votre apprentissage" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="youtubeSearchField" promptText="Rechercher une vidéo..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: transparent; -fx-padding: 12 15; -fx-font-size: 13px;"/>
                    <Button text="🔍 Rechercher" onAction="#rechercherVideosYouTube"
                            style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
                </HBox>
                <HBox fx:id="youtubeLoading" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator prefWidth="30" prefHeight="30"/>
                    <Label text="Recherche en cours..." style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </HBox>
                <ScrollPane fx:id="youtubeScrollPane" fitToWidth="true" prefHeight="300" visible="false" managed="false"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox spacing="10" fx:id="youtubeResultsContainer" style="-fx-padding: 10 0 10 0;"/>
                </ScrollPane>
                <VBox fx:id="youtubeEmptyMessage" alignment="CENTER" spacing="10" visible="false" managed="false">
                    <Label text="📭" style="-fx-font-size: 32px;"/>
                    <Label text="Aucune vidéo trouvée" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    <Label text="Essayez un autre mot-clé" style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.6);"/>
                </VBox>
            </VBox>
            <!-- SECTION 6 : JEU ÉDUCATIF (ORANGE) -->
            <VBox spacing="16" style="-fx-background-color: #EA580C; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 24;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30;">
                        <Label text="🎮" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Jeu éducatif" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Choisissez votre jeu et testez vos connaissances" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                </HBox>

                <!-- Sélecteur de jeu et niveau -->
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <Label text="Type de jeu :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <ComboBox fx:id="gameTypeCombo" promptText="Choisissez un jeu" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 8 15;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="📝 Quiz"/>
                                <String fx:value="🃏 Compléter la phrase"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Label text="Niveau :" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                    <ComboBox fx:id="gameLevelCombo" promptText="Choisissez un niveau" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 8 15;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="A1 - Débutant"/>
                                <String fx:value="A2 - Élémentaire"/>
                                <String fx:value="B1 - Intermédiaire"/>
                                <String fx:value="B2 - Avancé"/>
                                <String fx:value="C1 - Expert"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Button fx:id="startGameBtn" text="🎲 Commencer le jeu" onAction="#startGame"
                            style="-fx-background-color: white; -fx-text-fill: #EA580C; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 24; -fx-cursor: hand;"/>
                </HBox>

                <!-- Indicateur de chargement -->
                <HBox fx:id="gameLoading" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator prefWidth="30" prefHeight="30"/>
                    <Label text="Génération du jeu en cours..." style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                </HBox>

                <!-- Zone du quiz -->
                <VBox fx:id="quizContainer" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 16; -fx-padding: 20;">
                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="quizScore" text="Score: 0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
                    </HBox>
                    <ProgressBar fx:id="quizProgress" prefWidth="Infinity" progress="0" style="-fx-accent: #FFD700;"/>
                    <Label fx:id="quizQuestion" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-wrap-text: true;"/>
                    <VBox spacing="10" fx:id="quizAnswersContainer"/>
                    <Button fx:id="nextQuestionBtn" text="Question suivante →" onAction="#nextQuestion"
                            style="-fx-background-color: #FFD700; -fx-text-fill: #EA580C; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;" visible="false" managed="false"/>
                    <VBox fx:id="quizResultContainer" spacing="10" alignment="CENTER" visible="false" managed="false">
                        <Label fx:id="quizFinalScore" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
                        <Label fx:id="quizFeedback" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.9); -fx-wrap-text: true;" textAlignment="CENTER"/>
                        <Button text="🔄 Nouveau jeu" onAction="#startGame"
                                style="-fx-background-color: white; -fx-text-fill: #EA580C; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 24; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>



                <!-- Zone du jeu "Compléter la phrase" -->
                <VBox fx:id="fillGameContainer" spacing="15" visible="false" managed="false"
                      style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 16; -fx-padding: 20;">

                    <Label text="📝 COMPLÉTER LA PHRASE" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>

                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="fillScore" text="Score: 0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
                    </HBox>

                    <ProgressBar fx:id="fillProgress" prefWidth="Infinity" progress="0" style="-fx-accent: #FFD700;"/>

                    <!-- Question -->
                    <Label fx:id="fillQuestion" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-wrap-text: true;"/>

                    <!-- Options (boutons) -->
                    <VBox spacing="10" fx:id="fillOptionsContainer"/>

                    <!-- Bouton suivant -->
                    <Button fx:id="fillNextBtn" text="Question suivante →" onAction="#nextFillQuestion"
                            style="-fx-background-color: #FFD700; -fx-text-fill: #EA580C; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 20; -fx-cursor: hand;" visible="false" managed="false"/>

                    <!-- Résultat final -->
                    <VBox fx:id="fillResultContainer" spacing="10" alignment="CENTER" visible="false" managed="false">
                        <Label fx:id="fillFinalScore" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
                        <Label fx:id="fillFeedback" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.9); -fx-wrap-text: true;" textAlignment="CENTER"/>
                        <Button text="🔄 Nouveau jeu" onAction="#startGame"
                                style="-fx-background-color: white; -fx-text-fill: #EA580C; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 24; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>
            </VBox>
            <!-- SECTION 5 : MES COURS PDF (VERT) -->
            <VBox spacing="16" style="-fx-background-color: #10B981; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 15, 0, 0, 5); -fx-padding: 24;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30;">
                        <Label text="📚" style="-fx-font-size: 32px; -fx-padding: 12;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Mes cours personnalisés" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Retrouvez ici tous les cours PDF que vous avez générés" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                    <Label fx:id="totalCoursCount" text="0 cours"
                           style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 12px; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 5 12 5 12;"/>
                </HBox>
                <Separator style="-fx-background-color: rgba(255,255,255,0.2);"/>
                <ScrollPane fx:id="coursPdfScroll" fitToWidth="true" fitToHeight="false" visible="false" managed="false"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <HBox fx:id="coursPdfContainer" spacing="16" alignment="CENTER_LEFT" style="-fx-padding: 10 0 10 0;"/>
                </ScrollPane>
                <VBox fx:id="emptyCoursMessage" alignment="CENTER" spacing="10" visible="true" managed="true"
                      style="-fx-padding: 20 0 20 0;">
                    <Label text="📭" style="-fx-font-size: 48px;"/>
                    <Label text="Aucun cours généré" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9);"/>
                    <Label text="Utilisez 'Générer un cours personnalisé'" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                </VBox>
            </VBox>

            <!-- SECTION 6 : PARCOURS D'APPRENTISSAGE -->
            <VBox spacing="8">
                <Label text="🎯 Parcours d'apprentissage" style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                <Label text="Progressez niveau par niveau avec nos cours interactifs" style="-fx-font-size: 13px; -fx-text-fill: #8A8FA8;"/>
            </VBox>

            <!-- Niveaux A1 à C2 -->
            <VBox fx:id="niveauA1" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="A1" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #6C63FF;"/>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Débutant" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Les bases de la langue" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Label fx:id="progressA1" text="0/3 cours" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                </HBox>
                <HBox fx:id="coursA1" spacing="20" alignment="CENTER"/>
            </VBox>

            <VBox fx:id="niveauA2" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="A2" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #8B5CF6;"/>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Élémentaire" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Communication simple" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Label fx:id="progressA2" text="0/3 cours" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                </HBox>
                <HBox fx:id="coursA2" spacing="20" alignment="CENTER"/>
            </VBox>

            <VBox fx:id="niveauB1" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="B1" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #F59E0B;"/>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Intermédiaire" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Compréhension de sujets familiers" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Label fx:id="progressB1" text="0/3 cours" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                </HBox>
                <HBox fx:id="coursB1" spacing="20" alignment="CENTER"/>
            </VBox>

            <VBox fx:id="niveauB2" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="B2" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #EF4444;"/>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Intermédiaire supérieur" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Interaction fluide" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Label fx:id="progressB2" text="0/3 cours" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                </HBox>
                <HBox fx:id="coursB2" spacing="20" alignment="CENTER"/>
            </VBox>

            <VBox fx:id="niveauC1" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="C1" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #EC4899;"/>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Avancé" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Expression spontanée" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Label fx:id="progressC1" text="0/3 cours" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                </HBox>
                <HBox fx:id="coursC1" spacing="20" alignment="CENTER"/>
            </VBox>

            <VBox fx:id="niveauC2" spacing="12" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2); -fx-padding: 20;">
                <HBox alignment="CENTER_LEFT" spacing="16">
                    <Label text="C2" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #14B8A6;"/>
                    <VBox HBox.hgrow="ALWAYS">
                        <Label text="Maîtrise" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1A1D2E;"/>
                        <Label text="Compréhension quasi complète" style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8;"/>
                    </VBox>
                    <Label fx:id="progressC2" text="0/3 cours" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #10B981;"/>
                </HBox>
                <HBox fx:id="coursC2" spacing="20" alignment="CENTER"/>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>