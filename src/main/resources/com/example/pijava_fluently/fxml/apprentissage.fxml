<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.collections.FXCollections?>

<?import java.lang.String?>
<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.ApprentissageController"
      spacing="0" style="-fx-background-color: linear-gradient(to bottom, #F8FAFC, #F1F5F9);">

    <!-- Header avec dégradé élégant -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color: linear-gradient(to right, #4F46E5, #7C3AED); -fx-effect: dropshadow(gaussian, rgba(79,70,229,0.25), 10, 0, 0, 2);">
        <padding><Insets top="20" left="32" right="32" bottom="20"/></padding>
        <Button text="← Retour"
                style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 18 8 18; -fx-cursor: hand;"
                onAction="#handleRetour"/>
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label fx:id="langueNom" text="Français" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label fx:id="langueDescription" text="Langue de Molière" style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
        </VBox>
        <VBox alignment="CENTER_RIGHT" spacing="4"
              style="-fx-background-color: rgba(255,255,255,0.15); -fx-background-radius: 16; -fx-padding: 8 16 8 16;">
            <Label text="Niveau actuel" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7);"/>
            <Label fx:id="niveauActuelValue" text="Non défini" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="24">
            <padding><Insets top="30" left="40" right="40" bottom="40"/></padding>

            <!-- SECTION 1 : TEST DE NIVEAU - Bleu glacier -->
            <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #EFF6FF, #DBEAFE); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4); -fx-padding: 24; -fx-border-color: #BFDBFE; -fx-border-radius: 20; -fx-border-width: 1;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #3B82F6; -fx-background-radius: 30;">
                        <Label text="📝" style="-fx-font-size: 28px; -fx-padding: 10;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Évaluez votre niveau" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E3A5F;"/>
                        <Label text="Passez notre test de niveau pour un parcours personnalisé" style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
                    </VBox>
                    <Button text="Commencer le test →"
                            style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24 12 24; -fx-cursor: hand;"
                            onAction="#handleTest"/>
                </HBox>
            </VBox>

            <!-- SECTION 2 : GÉNÉRATION DE COURS - Violet doux -->
            <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #F5F3FF, #EDE9FE); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4); -fx-padding: 24; -fx-border-color: #DDD6FE; -fx-border-radius: 20; -fx-border-width: 1;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #8B5CF6; -fx-background-radius: 30;">
                        <Label text="✨" style="-fx-font-size: 28px; -fx-padding: 10;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Générer un cours personnalisé" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4C1D95;"/>
                        <Label text="Créez un cours sur mesure selon vos besoins" style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>
                    </VBox>
                    <Button fx:id="btnOuvrirFormCours" text="Créer mon cours →"
                            style="-fx-background-color: #8B5CF6; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24 12 24; -fx-cursor: hand;"
                            onAction="#ouvrirFormulaireCours"/>
                </HBox>
            </VBox>

            <!-- Formulaire (caché par défaut) - DESIGN AMÉLIORÉ -->
            <VBox fx:id="formCoursContainer" spacing="0" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-background-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 8);">

                <!-- En-tête du formulaire -->
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color: linear-gradient(to right, #8B5CF6, #A78BFA); -fx-background-radius: 24 24 0 0; -fx-padding: 20 28;">
                    <StackPane style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 30; -fx-padding: 10;">
                        <Label text="📖" style="-fx-font-size: 28px;"/>
                    </StackPane>
                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="Personnalisez votre cours" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                        <Label text="Remplissez les champs ci-dessous pour générer un cours adapté à vos besoins"
                               style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8);"/>
                    </VBox>
                    <Button text="✕ Fermer"
                            style="-fx-background-color: rgba(255,255,255,0.2); -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 8 18; -fx-cursor: hand;"
                            onAction="#fermerFormulaireCours"/>
                </HBox>

                <VBox spacing="24" style="-fx-padding: 28;">

                    <!-- Thème du cours -->
                    <VBox spacing="12">
                        <Label text="🎯 Thème du cours" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4C1D95;"/>
                        <Label text="Choisissez un thème qui vous intéresse" style="-fx-font-size: 11px; -fx-text-fill: #8A8FA8;"/>
                        <TextField fx:id="fieldTheme" promptText="Ex: Voyage, Affaires, Cuisine, Technologie..."
                                   style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #DDD6FE; -fx-border-radius: 12; -fx-padding: 12 16; -fx-font-size: 13px;"/>
                        <Label text="Suggestions :" style="-fx-font-size: 11px; -fx-text-fill: #6C63FF; -fx-font-weight: bold;"/>
                        <FlowPane fx:id="themeSuggestionsContainer" hgap="10" vgap="10"/>
                    </VBox>

                    <!-- Point de grammaire avec sélection multiple -->
                    <VBox spacing="12">
                        <Label text="📚 Points de grammaire" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4C1D95;"/>
                        <Label text="Sélectionnez les points de grammaire à réviser" style="-fx-font-size: 11px; -fx-text-fill: #8A8FA8;"/>
                        <TextField fx:id="fieldGrammaire" promptText="Ou écrivez votre propre point de grammaire..."
                                   style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #DDD6FE; -fx-border-radius: 12; -fx-padding: 12 16; -fx-font-size: 13px;"/>
                        <Label text="Suggestions (cliquez pour ajouter) :" style="-fx-font-size: 11px; -fx-text-fill: #6C63FF; -fx-font-weight: bold;"/>
                        <FlowPane fx:id="grammaireSuggestionsContainer" hgap="10" vgap="10"/>
                        <Label fx:id="grammaireSelectedLabel" text="Sélectionnés : aucun"
                               style="-fx-font-size: 11px; -fx-text-fill: #10B981; -fx-font-style: italic; -fx-background-color: #D1FAE5; -fx-background-radius: 15; -fx-padding: 4 12;"/>
                    </VBox>

                    <!-- Vocabulaire avec suggestions dynamiques -->
                    <VBox spacing="12">
                        <Label text="📝 Vocabulaire" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4C1D95;"/>
                        <Label text="Ajoutez les mots de vocabulaire que vous souhaitez apprendre" style="-fx-font-size: 11px; -fx-text-fill: #8A8FA8;"/>
                        <TextField fx:id="fieldVocabulaire" promptText="Mots séparés par des virgules..."
                                   style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #DDD6FE; -fx-border-radius: 12; -fx-padding: 12 16; -fx-font-size: 13px;"/>
                        <Label text="Suggestions basées sur votre thème :" style="-fx-font-size: 11px; -fx-text-fill: #6C63FF; -fx-font-weight: bold;"/>
                        <FlowPane fx:id="vocabulaireSuggestionsContainer" hgap="10" vgap="10"/>
                    </VBox>

                    <!-- Sélection du niveau -->
                    <VBox spacing="12">
                        <Label text="⭐ Sélectionnez votre niveau" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4C1D95;"/>
                        <Label text="Choisissez le niveau qui correspond à votre maîtrise" style="-fx-font-size: 11px; -fx-text-fill: #8A8FA8;"/>
                        <HBox spacing="16" alignment="CENTER">
                            <VBox alignment="CENTER" spacing="8" fx:id="niveauA1Btn" onMouseClicked="#selectionnerNiveauA1" style="-fx-cursor: hand;">
                                <StackPane style="-fx-background-color: #6C63FF; -fx-background-radius: 45; -fx-padding: 14;">
                                    <Label text="A1" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                                <Label text="Débutant" style="-fx-font-size: 10px; -fx-text-fill: #6C63FF;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" fx:id="niveauA2Btn" onMouseClicked="#selectionnerNiveauA2" style="-fx-cursor: hand;">
                                <StackPane style="-fx-background-color: #8B5CF6; -fx-background-radius: 45; -fx-padding: 14;">
                                    <Label text="A2" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                                <Label text="Élémentaire" style="-fx-font-size: 10px; -fx-text-fill: #8B5CF6;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" fx:id="niveauB1Btn" onMouseClicked="#selectionnerNiveauB1" style="-fx-cursor: hand;">
                                <StackPane style="-fx-background-color: #F59E0B; -fx-background-radius: 45; -fx-padding: 14;">
                                    <Label text="B1" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                                <Label text="Intermédiaire" style="-fx-font-size: 10px; -fx-text-fill: #F59E0B;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" fx:id="niveauB2Btn" onMouseClicked="#selectionnerNiveauB2" style="-fx-cursor: hand;">
                                <StackPane style="-fx-background-color: #EF4444; -fx-background-radius: 45; -fx-padding: 14;">
                                    <Label text="B2" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                                <Label text="Avancé" style="-fx-font-size: 10px; -fx-text-fill: #EF4444;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" fx:id="niveauC1Btn" onMouseClicked="#selectionnerNiveauC1" style="-fx-cursor: hand;">
                                <StackPane style="-fx-background-color: #EC4899; -fx-background-radius: 45; -fx-padding: 14;">
                                    <Label text="C1" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                                <Label text="Autonome" style="-fx-font-size: 10px; -fx-text-fill: #EC4899;"/>
                            </VBox>
                            <VBox alignment="CENTER" spacing="8" fx:id="niveauC2Btn" onMouseClicked="#selectionnerNiveauC2" style="-fx-cursor: hand;">
                                <StackPane style="-fx-background-color: #14B8A6; -fx-background-radius: 45; -fx-padding: 14;">
                                    <Label text="C2" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                                </StackPane>
                                <Label text="Maîtrise" style="-fx-font-size: 10px; -fx-text-fill: #14B8A6;"/>
                            </VBox>
                        </HBox>
                        <Label fx:id="niveauSelectionneLabel" text="Niveau sélectionné : Aucun"
                               style="-fx-font-size: 12px; -fx-text-fill: #8A8FA8; -fx-background-color: #F4F5FA; -fx-background-radius: 15; -fx-padding: 6 16; -fx-max-width: 200;"/>
                    </VBox>

                    <!-- Aperçu du cours -->
                    <VBox spacing="12">
                        <Label text="📄 Aperçu du cours" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #4C1D95;"/>
                        <TextArea fx:id="apercuCours" editable="false" wrapText="true" prefHeight="280"
                                  style="-fx-background-color: #F8F9FD; -fx-background-radius: 12; -fx-border-color: #DDD6FE; -fx-border-radius: 12; -fx-font-size: 13px; -fx-font-family: 'Segoe UI'; -fx-text-fill: #1E293B; -fx-padding: 12;"/>
                    </VBox>

                    <!-- Loading -->
                    <HBox fx:id="loadingContainer" alignment="CENTER" spacing="15" visible="false" managed="false">
                        <ProgressIndicator fx:id="loadingIA" prefWidth="40" prefHeight="40"/>
                        <Label fx:id="loadingText" text="🤖 Génération du cours en cours..." style="-fx-font-size: 13px; -fx-text-fill: #8B5CF6; -fx-font-weight: bold;"/>
                    </HBox>

                    <!-- Boutons d'action -->
                    <HBox spacing="15" alignment="CENTER_RIGHT">
                        <Button text="🗑️ Effacer"
                                style="-fx-background-color: #F4F5FA; -fx-text-fill: #4A4D6A; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 24; -fx-cursor: hand; -fx-border-color: #E0E3F0; -fx-border-radius: 12;"
                                onAction="#effacerFormulaire"/>
                        <Button fx:id="btnGenererCours" text="🔄 Générer le cours"
                                style="-fx-background-color: #8B5CF6; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 28; -fx-cursor: hand;"
                                onAction="#genererCours"/>
                        <Button fx:id="btnExporterPDF" text="📥 Exporter en PDF" disable="true"
                                style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 10 28; -fx-cursor: hand;"
                                onAction="#exporterPDF"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- RESTE DU FICHIER IDENTIQUE... -->

            <!-- SECTION 3 : DICTIONNAIRE - Vert sauge -->
            <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #ECFDF5, #D1FAE5); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4); -fx-padding: 24; -fx-border-color: #A7F3D0; -fx-border-radius: 20; -fx-border-width: 1;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #10B981; -fx-background-radius: 30;">
                        <Label text="📖" style="-fx-font-size: 28px; -fx-padding: 10;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Dictionnaire" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #064E3B;"/>
                        <Label text="Trouvez la définition, traduction et exemples d'un mot" style="-fx-font-size: 13px; -fx-text-fill: #047857;"/>
                    </VBox>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="dictionarySearchField" promptText="Entrez un mot à définir..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #A7F3D0; -fx-border-radius: 12; -fx-padding: 12 15; -fx-font-size: 13px;"/>
                    <Button text="🔍 Chercher" onAction="#chercherMotDictionnaire"
                            style="-fx-background-color: #10B981; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
                </HBox>
                <HBox fx:id="dictionaryLoading" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator prefWidth="30" prefHeight="30"/>
                    <Label text="Recherche en cours..." style="-fx-font-size: 12px; -fx-text-fill: #064E3B;"/>
                </HBox>
                <VBox fx:id="dictionaryResultContainer" spacing="12" visible="false" managed="false"
                      style="-fx-background-color: rgba(16,185,129,0.1); -fx-background-radius: 16; -fx-padding: 16; -fx-border-color: #A7F3D0; -fx-border-radius: 16; -fx-border-width: 1;">
                    <Label fx:id="dictionaryWord" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #064E3B;"/>
                    <Label fx:id="dictionaryDefinition" wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #065F46;"/>
                    <Label fx:id="dictionaryExample" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #047857; -fx-font-style: italic;"/>
                    <Label fx:id="dictionarySynonym" wrapText="true" style="-fx-font-size: 12px; -fx-text-fill: #047857;"/>
                </VBox>
                <VBox fx:id="dictionaryEmptyMessage" alignment="CENTER" spacing="10" visible="false" managed="false">
                    <Label text="📭" style="-fx-font-size: 32px;"/>
                    <Label text="Aucun résultat" style="-fx-font-size: 13px; -fx-text-fill: #064E3B;"/>
                </VBox>
            </VBox>

            <!-- SECTION 4 : RECHERCHE YOUTUBE - Rouge élégant -->
            <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #FEF2F2, #FEE2E2); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4); -fx-padding: 24; -fx-border-color: #FECACA; -fx-border-radius: 20; -fx-border-width: 1;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #EF4444; -fx-background-radius: 30;">
                        <Label text="🎬" style="-fx-font-size: 28px; -fx-padding: 10;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Vidéos YouTube" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #7F1D1D;"/>
                        <Label text="Trouvez des vidéos pour améliorer votre apprentissage" style="-fx-font-size: 13px; -fx-text-fill: #991B1B;"/>
                    </VBox>
                </HBox>
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="youtubeSearchField" promptText="Rechercher une vidéo..." HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #FECACA; -fx-border-radius: 12; -fx-padding: 12 15; -fx-font-size: 13px;"/>
                    <Button text="🔍 Rechercher" onAction="#rechercherVideosYouTube"
                            style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
                </HBox>
                <HBox fx:id="youtubeLoading" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator prefWidth="30" prefHeight="30"/>
                    <Label text="Recherche en cours..." style="-fx-font-size: 12px; -fx-text-fill: #7F1D1D;"/>
                </HBox>
                <ScrollPane fx:id="youtubeScrollPane" fitToWidth="true" prefHeight="300" visible="false" managed="false"
                            style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox spacing="10" fx:id="youtubeResultsContainer" style="-fx-padding: 10 0 10 0;"/>
                </ScrollPane>
                <VBox fx:id="youtubeEmptyMessage" alignment="CENTER" spacing="10" visible="false" managed="false">
                    <Label text="📭" style="-fx-font-size: 32px;"/>
                    <Label text="Aucune vidéo trouvée" style="-fx-font-size: 13px; -fx-text-fill: #7F1D1D;"/>
                    <Label text="Essayez un autre mot-clé" style="-fx-font-size: 11px; -fx-text-fill: #991B1B;"/>
                </VBox>
            </VBox>

            <!-- SECTION 5 : PRONONCIATION - Bleu océan -->
            <VBox spacing="16" style="-fx-background-color: linear-gradient(to bottom right, #EFF6FF, #DBEAFE); -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4); -fx-padding: 24; -fx-border-color: #BFDBFE; -fx-border-radius: 20; -fx-border-width: 1;">
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #3B82F6; -fx-background-radius: 30;">
                        <Label text="🔊" style="-fx-font-size: 28px; -fx-padding: 10;"/>
                    </StackPane>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Prononciation" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E3A5F;"/>
                        <Label text="Écoutez la prononciation d'un mot ou d'une phrase" style="-fx-font-size: 13px; -fx-text-fill: #3B82F6;"/>
                    </VBox>
                </HBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <TextField fx:id="pronunciationTextField" promptText="Entrez un mot ou une phrase à écouter..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #BFDBFE; -fx-border-radius: 12; -fx-padding: 12 15; -fx-font-size: 13px;"/>
                    <Button text="🔊 Écouter" onAction="#prononcer"
                            style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-size: 13px; -fx-font-weight: bold; -fx-background-radius: 12; -fx-padding: 12 24; -fx-cursor: hand;"/>
                </HBox>

                <HBox fx:id="pronunciationLoading" alignment="CENTER" spacing="15" visible="false" managed="false">
                    <ProgressIndicator prefWidth="25" prefHeight="25"/>
                    <Label text="Lecture en cours..." style="-fx-font-size: 12px; -fx-text-fill: #1E3A5F;"/>
                </HBox>

                <VBox spacing="8">
                    <Label text="Suggestions :" style="-fx-font-size: 12px; -fx-text-fill: #1E3A5F;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Bonjour" style="-fx-background-color: #3B82F6; -fx-text-fill: white; -fx-font-size: 11px; -fx-background-radius: 15; -fx-padding: 5 12; -fx-cursor: hand;" onAction="#suggestionBonjour"/>
