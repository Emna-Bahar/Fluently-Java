<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.pijava_fluently.controller.LanguagePickerController"
           styleClass="lp-root"
           prefWidth="700" prefHeight="520">

    <!-- Gradient background card -->
    <VBox alignment="CENTER" spacing="28" styleClass="lp-card" maxWidth="580">
        <padding><Insets top="48" right="40" bottom="40" left="40"/></padding>

        <!-- Mascot / headline -->
        <Label text="🌍" style="-fx-font-size:56px;"/>
        <Label fx:id="welcomeLabel"
               text="Welcome! Which language do you want to study?"
               styleClass="lp-welcome"
               wrapText="true"
               textAlignment="CENTER"/>

        <!-- Language choice buttons grid -->
        <FlowPane fx:id="languagePane"
                  hgap="12" vgap="12"
                  alignment="CENTER"
                  styleClass="lp-flow"/>

        <!-- Generating spinner (hidden until a language is chosen) -->
        <VBox fx:id="generatingBox" alignment="CENTER" spacing="14"
              visible="false" managed="false">
            <ProgressIndicator fx:id="spinner" prefWidth="42" prefHeight="42"
                               styleClass="lp-spinner"/>
            <Label fx:id="statusLabel" text="Generating your avatar…"
                   styleClass="lp-status"/>
        </VBox>
    </VBox>
</StackPane>
