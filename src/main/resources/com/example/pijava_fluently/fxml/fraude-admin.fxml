<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.FraudeAdminController"
      spacing="0" style="-fx-background-color:#F0F2FF;">

    <VBox style="-fx-background-color:white;-fx-padding:24 32;
                 -fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">
        <Label text="🚨 Surveillance des examens — Tableau de fraude"
               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
        <Label text="Historique complet des infractions détectées par l'IA"
               style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>
    </VBox>

    <!-- Tableau des étudiants suspects -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-border-color:transparent;">
        <VBox fx:id="vboxInfractions" spacing="10"
              style="-fx-padding:24 32;">
            <Label text="Chargement..." style="-fx-text-fill:#8A8FA8;"/>
        </VBox>
    </ScrollPane>
</VBox>