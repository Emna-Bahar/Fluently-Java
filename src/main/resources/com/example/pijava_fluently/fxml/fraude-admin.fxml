<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.FraudeAdminController"
      spacing="0" style="-fx-background-color:#F0F2FF;">

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white;-fx-padding:22 32;
                 -fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">
        <StackPane style="-fx-background-color:#FEF2F2;-fx-background-radius:12;
                          -fx-min-width:44;-fx-min-height:44;
                          -fx-max-width:44;-fx-max-height:44;">
            <Label text="🚨" style="-fx-font-size:20px;"/>
        </StackPane>
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label text="Surveillance des Examens"
                   style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <Label text="Statistiques détaillées des comportements suspects détectés par l'IA"
                   style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;
                       -fx-border-color:transparent;">
        <VBox spacing="20" style="-fx-padding:24 32 32 32;">

            <!-- ══ CARTES STATS ══ -->
            <HBox spacing="14">
                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                      style="-fx-background-color:white;-fx-background-radius:14;
                             -fx-padding:20;
                             -fx-border-color:#FECACA;-fx-border-radius:14;-fx-border-width:1;">
                    <Label text="⚠️" style="-fx-font-size:24px;"/>
                    <Label fx:id="labelTotalInfractions" text="0"
                           style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#DC2626;"/>
                    <Label text="Total infractions"
                           style="-fx-font-size:11px;-fx-text-fill:#9CA3AF;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                      style="-fx-background-color:white;-fx-background-radius:14;
                             -fx-padding:20;
                             -fx-border-color:#FDE68A;-fx-border-radius:14;-fx-border-width:1;">
                    <Label text="👁️" style="-fx-font-size:24px;"/>
                    <Label fx:id="labelEtudiantsSurveilles" text="0"
                           style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#D97706;"/>
                    <Label text="Étudiants surveillés"
                           style="-fx-font-size:11px;-fx-text-fill:#9CA3AF;"/>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
                      style="-fx-background-color:white;-fx-background-radius:14;
                             -fx-padding:20;
                             -fx-border-color:#FECACA;-fx-border-radius:14;-fx-border-width:1;">
                    <Label text="🔴" style="-fx-font-size:24px;"/>
                    <Label fx:id="labelRisqueHaut" text="0"
                           style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#991B1B;"/>
                    <Label text="Haut risque (6+)"
                           style="-fx-font-size:11px;-fx-text-fill:#9CA3AF;"/>
                </VBox>
            </HBox>

            <!-- ══ GRAPHIQUE ══ -->
            <VBox spacing="0"
                  style="-fx-background-color:white;-fx-background-radius:14;
                         -fx-border-color:#E8EAF0;-fx-border-radius:14;-fx-border-width:1;">
                <HBox style="-fx-padding:16 20;
                             -fx-border-color:#F0F1F7;-fx-border-width:0 0 1 0;">
                    <Label text="📊 Infractions par type"
                           style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                </HBox>
                <BarChart fx:id="barChart" prefHeight="220"
                          animated="false" legendVisible="false"
                          style="-fx-background-color:transparent;">
                    <xAxis><CategoryAxis/></xAxis>
                    <yAxis><NumberAxis/></yAxis>
                </BarChart>
            </VBox>

            <!-- ══ LISTE DES ÉTUDIANTS ══ -->
            <VBox spacing="0"
                  style="-fx-background-color:white;-fx-background-radius:14;
                         -fx-border-color:#E8EAF0;-fx-border-radius:14;-fx-border-width:1;">
                <HBox style="-fx-padding:16 20;
                             -fx-border-color:#F0F1F7;-fx-border-width:0 0 1 0;">
                    <Label text="👥 Profils des étudiants surveillés"
                           style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                </HBox>
                <VBox fx:id="vboxListe" spacing="12"
                      style="-fx-padding:16 20 20 20;">
                    <Label text="Chargement..."
                           style="-fx-text-fill:#8A8FA8;-fx-font-size:13px;"/>
                </VBox>
            </VBox>

        </VBox>
    </ScrollPane>
</VBox>