<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.QuestionController"
      spacing="0" style="-fx-background-color:#F0F2FF;">

    <HBox alignment="CENTER_LEFT" spacing="20"
          style="-fx-background-color:white;-fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;
                 -fx-effect:dropshadow(gaussian,rgba(108,99,255,0.08),12,0,0,3);">
        <padding><Insets top="20" left="32" right="32" bottom="20"/></padding>
        <StackPane style="-fx-background-color:#FFF0F5;-fx-background-radius:14;
                          -fx-min-width:48;-fx-min-height:48;-fx-max-width:48;-fx-max-height:48;">
            <Label text="❓" style="-fx-font-size:22px;"/>
        </StackPane>
        <VBox HBox.hgrow="ALWAYS" spacing="2">
            <Label text="Gestion des Questions"
                   style="-fx-font-size:20px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <Label text="Ajoutez et gérez les questions associées aux tests"
                   style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
        </VBox>
        <Button text="＋  Ajouter une question" onAction="#handleAjouter"
                style="-fx-background-color:linear-gradient(to right,#EC4899,#F43F5E);
                       -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                       -fx-background-radius:12;-fx-padding:11 22;-fx-cursor:hand;
                       -fx-border-color:transparent;
                       -fx-effect:dropshadow(gaussian,rgba(236,72,153,0.38),10,0,0,4);"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;
                       -fx-border-color:transparent;">
        <VBox spacing="20">
            <padding><Insets top="24" left="28" right="28" bottom="28"/></padding>

            <!-- FORMULAIRE -->
            <VBox fx:id="formCard" visible="false" managed="false" spacing="0"
                  style="-fx-background-color:white;-fx-background-radius:20;
                         -fx-effect:dropshadow(gaussian,rgba(236,72,153,0.12),22,0,0,7);
                         -fx-border-color:#FCE7F3;-fx-border-radius:20;-fx-border-width:1;">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-background-color:linear-gradient(to right,#EC4899,#F43F5E);
                             -fx-background-radius:20 20 0 0;-fx-padding:16 24;">
                    <Label text="✏️" style="-fx-font-size:16px;"/>
                    <Label fx:id="formTitle" text="Nouvelle Question"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="* champs obligatoires"
                           style="-fx-font-size:11px;-fx-text-fill:rgba(255,255,255,0.7);"/>
                </HBox>
                <VBox spacing="16">
                    <padding><Insets top="22" left="28" right="28" bottom="22"/></padding>
                    <VBox spacing="5">
                        <Label text="ÉNONCÉ *"
                               style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#9CA3AF;"/>
                        <TextArea fx:id="fieldEnonce" promptText="Écrivez l'énoncé de la question…"
                                  prefRowCount="3" wrapText="true"
                                  style="-fx-background-color:#F9FAFB;-fx-background-radius:10;
                                         -fx-border-color:#E5E7EB;-fx-border-radius:10;
                                         -fx-padding:10 14;-fx-font-size:13px;"/>
                    </VBox>
                    <HBox spacing="16">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="TYPE *"
                                   style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#9CA3AF;"/>
                            <ComboBox fx:id="comboType" maxWidth="Infinity" promptText="Sélectionner…"
                                      style="-fx-background-color:#F9FAFB;-fx-border-color:#E5E7EB;
                                             -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                        </VBox>
                        <VBox spacing="5" prefWidth="140">
                            <Label text="SCORE MAX *"
                                   style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#9CA3AF;"/>
                            <TextField fx:id="fieldScoreMax" promptText="Ex : 2"
                                       style="-fx-background-color:#F9FAFB;-fx-border-color:#E5E7EB;
                                              -fx-border-radius:10;-fx-background-radius:10;
                                              -fx-padding:11 14;-fx-font-size:13px;"/>
                        </VBox>
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="TEST ASSOCIÉ *"
                                   style="-fx-font-size:10px;-fx-font-weight:bold;-fx-text-fill:#9CA3AF;"/>
                            <ComboBox fx:id="comboTest" maxWidth="Infinity" promptText="Sélectionner un test…"
                                      style="-fx-background-color:#F9FAFB;-fx-border-color:#E5E7EB;
                                             -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                        </VBox>
                    </HBox>
                    <Label fx:id="labelErreur" text="" visible="false" managed="false" wrapText="true"
                           style="-fx-font-size:12px;-fx-text-fill:#DC2626;-fx-background-color:#FEF2F2;
                                  -fx-background-radius:10;-fx-border-color:#FECACA;-fx-border-radius:10;
                                  -fx-border-width:1;-fx-padding:10 14;"/>
                    <Separator style="-fx-background-color:#F3F4F6;"/>
                    <HBox spacing="10" alignment="CENTER_RIGHT">
                        <Button text="✕  Annuler" onAction="#handleCancel"
                                style="-fx-background-color:white;-fx-text-fill:#6B7280;
                                       -fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:10;
                                       -fx-padding:10 22;-fx-cursor:hand;-fx-border-color:#E5E7EB;
                                       -fx-border-radius:10;-fx-border-width:1.5;"/>
                        <Button text="💾  Enregistrer" onAction="#handleSave"
                                style="-fx-background-color:linear-gradient(to right,#EC4899,#F43F5E);
                                       -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                                       -fx-background-radius:10;-fx-padding:10 24;-fx-cursor:hand;
                                       -fx-border-color:transparent;
                                       -fx-effect:dropshadow(gaussian,rgba(236,72,153,0.35),10,0,0,3);"/>
                    </HBox>
                </VBox>
            </VBox>

            <!-- TABLE CARD -->
            <VBox spacing="0"
                  style="-fx-background-color:white;-fx-background-radius:20;
                         -fx-effect:dropshadow(gaussian,rgba(236,72,153,0.07),20,0,0,6);
                         -fx-border-color:#FCE7F3;-fx-border-radius:20;-fx-border-width:1.5;">
                <HBox alignment="CENTER_LEFT" spacing="16"
                      style="-fx-background-color:linear-gradient(to right,#FFF5F8,#FFF0F5);
                             -fx-background-radius:20 20 0 0;
                             -fx-padding:18 24;
                             -fx-border-color:transparent transparent #FCE7F3 transparent;
                             -fx-border-width:0 0 1.5 0;">
                    <VBox spacing="3" HBox.hgrow="ALWAYS">
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="❓" style="-fx-font-size:16px;"/>
                            <Label text="Liste des Questions"
                                   style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                            <Label fx:id="countLabel" text="0 question(s)"
                                   style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#EC4899;
                                          -fx-background-color:#FFF0F5;-fx-background-radius:20;
                                          -fx-padding:3 12;"/>
                        </HBox>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="300"
                          style="-fx-background-color:white;-fx-background-radius:30;
                                 -fx-padding:10 18;-fx-border-color:#FCE7F3;
                                 -fx-border-radius:30;-fx-border-width:1.5;
                                 -fx-effect:dropshadow(gaussian,rgba(236,72,153,0.08),8,0,0,2);">
                        <Label text="🔍" style="-fx-font-size:13px;-fx-text-fill:#EC4899;"/>
                        <TextField fx:id="searchField" promptText="Rechercher une question…"
                                   HBox.hgrow="ALWAYS" onKeyReleased="#handleSearch"
                                   style="-fx-background-color:transparent;-fx-border-color:transparent;
                                          -fx-font-size:13px;-fx-padding:0;-fx-text-fill:#1A1D2E;
                                          -fx-prompt-text-fill:#C0C4D8;"/>
                    </HBox>
                </HBox>
                <TableView fx:id="tableQuestions" VBox.vgrow="ALWAYS" prefHeight="440"
                           style="-fx-background-color:transparent;-fx-border-color:transparent;
                                  -fx-table-cell-border-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colId"      text="ID"      prefWidth="50" visible="false"/>
                        <TableColumn fx:id="colEnonce"  text="Énoncé"  prefWidth="300"/>
                        <TableColumn fx:id="colType"    text="Type"    prefWidth="130" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colScore"   text="Score"   prefWidth="90"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colTest"    text="Test"    prefWidth="150" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="310" style="-fx-alignment:CENTER;"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="16">
                            <padding><Insets top="70" bottom="70"/></padding>
                            <Label text="❓" style="-fx-font-size:60px;"/>
                            <Label text="Aucune question trouvée"
                                   style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#4A4D6A;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>