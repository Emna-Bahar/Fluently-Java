<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.StreakDashboardController"
            prefWidth="680" prefHeight="850"
            style="-fx-background-color:#0F172A;-fx-padding:0;">

    <content>
        <ScrollPane fitToWidth="true" style="-fx-background:#0F172A;-fx-background-color:#0F172A;-fx-border-color:transparent;">
            <VBox spacing="24" style="-fx-background-color:#0F172A;-fx-padding:20 24 30 24;">

                <!-- ══ HEADER ═══════════════════════════════════════════════════════ -->
                <HBox spacing="16" alignment="CENTER_LEFT">
                    <StackPane style="-fx-background-color: #FF6B35; -fx-background-radius: 50; -fx-min-width: 65; -fx-min-height: 65;">
                        <Label text="👤" style="-fx-font-size:32px;"/>
                    </StackPane>

                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label fx:id="lblUserName" text="Bonjour 👋" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#FFFFFF;"/>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblNiveauLabel" text="🌱 Graine"
                                   style="-fx-background-color:#FF6B3522;-fx-text-fill:#FF6B35;-fx-font-size:11px;-fx-font-weight:bold;
                                          -fx-background-radius:20;-fx-padding:4 14 4 14;"/>
                            <Label fx:id="lblNiveauNum" text="Niveau 1" style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                        </HBox>
                    </VBox>

                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="⭐ POINTS XP" style="-fx-font-size:9px;-fx-text-fill:#64748B;-fx-font-weight:bold;-fx-letter-spacing:1;"/>
                        <Label fx:id="lblTotalPoints" text="0" style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#FFD700;"/>
                    </VBox>
                </HBox>

                <!-- ══ PROGRESSION VERS PROCHAIN NIVEAU ═══════════════════════════════ -->
                <HBox spacing="20" alignment="CENTER" style="-fx-padding:5 0 0 0;">
                    <StackPane fx:id="arcContainer" minWidth="130" minHeight="130"/>

                    <VBox spacing="12" HBox.hgrow="ALWAYS">
                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label text="📊 Taux complétion" style="-fx-font-size:9px;-fx-text-fill:#64748B;"/>
                                <Label fx:id="lblTauxCompletion" text="0%" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#10B981;"/>
                            </VBox>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label text="✅ Tâches faites" style="-fx-font-size:9px;-fx-text-fill:#64748B;"/>
                                <Label fx:id="lblTachesTotal" text="0" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#F8FAFC;"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="16" alignment="CENTER_LEFT">
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label text="⏱ Temps d'étude" style="-fx-font-size:9px;-fx-text-fill:#64748B;"/>
                                <Label fx:id="lblDureeTotal" text="0m" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#3B82F6;"/>
                            </VBox>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label text="🎯 Sessions" style="-fx-font-size:9px;-fx-text-fill:#64748B;"/>
                                <Label fx:id="lblSessions" text="0" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#8B5CF6;"/>
                            </VBox>
                        </HBox>
                    </VBox>
                </HBox>

                <!-- ══ CARTE STREAK ═══════════════════════════════════════════════════ -->
                <VBox alignment="CENTER" spacing="8"
                      style="-fx-background-color:#1E293B;-fx-background-radius:24;
                             -fx-border-color:#FF6B35;-fx-border-width:1;-fx-border-radius:24;-fx-padding:24 20 20 20;">
                    <Label fx:id="lblStreakFire" text="🔥" style="-fx-font-size:48px;"/>
                    <Label fx:id="lblStreakCount" text="0" style="-fx-font-size:52px;-fx-font-weight:bold;-fx-text-fill:#FF6B35;"/>
                    <Label text="JOURS DE STREAK" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;-fx-letter-spacing:2;"/>
                    <ProgressBar fx:id="streakProgressBar" progress="0.0"
                                 style="-fx-accent: #FF6B35; -fx-background-radius: 10; -fx-padding: 0;"
                                 prefWidth="200" maxWidth="200"/>
                    <Label fx:id="lblStreakSub" text="Commencez aujourd'hui !" style="-fx-font-size:12px;-fx-text-fill:#94A3B8;"/>
                    <Label fx:id="lblStreakMax" text="🏆 Record : 0 jours" style="-fx-font-size:11px;-fx-text-fill:#FFD700;"/>
                </VBox>

                <!-- ══ SESSIONS RÉCENTES ══════════════════════════════════════════════ -->
                <VBox spacing="12">
                    <Label text="🕐 SESSIONS RÉCENTES" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#475569;-fx-letter-spacing:2;"/>
                    <VBox fx:id="sessionsContainer" spacing="8"/>
                </VBox>

                <!-- ══ ACTIVITÉ HEBDOMADAIRE ══════════════════════════════════════════ -->
                <VBox spacing="12"
                      style="-fx-background-color:#1E293B;-fx-background-radius:20;-fx-padding:16;">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="📈" style="-fx-font-size:16px;"/>
                        <Label text="Activité 7 derniers jours" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#F8FAFC;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblBestDay" text="" style="-fx-font-size:10px;-fx-text-fill:#FFD700;"/>
                    </HBox>
                    <HBox fx:id="hebdoChart" alignment="BOTTOM_CENTER" spacing="8" style="-fx-padding:10 0 5 0;"/>
                </VBox>

                <!-- ══ BADGES ═════════════════════════════════════════════════════════ -->
                <VBox spacing="12">
                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="🏅" style="-fx-font-size:16px;"/>
                        <Label text="BADGES" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#475569;-fx-letter-spacing:2;"/>
                        <Label fx:id="lblBadgesCount" text="0 badge(s)" style="-fx-font-size:11px;-fx-text-fill:#FFD700;"/>
                    </HBox>
                    <FlowPane fx:id="badgesContainer" hgap="10" vgap="10"
                              style="-fx-background-color:#1E293B;-fx-background-radius:20;-fx-padding:16;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="CLOSE"/>
    </buttonTypes>

</DialogPane>