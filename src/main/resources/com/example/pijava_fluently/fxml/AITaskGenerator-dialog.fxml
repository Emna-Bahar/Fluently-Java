<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<DialogPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.AITaskGeneratorController"
            prefWidth="560"
            style="-fx-background-color:#F8FAFC;-fx-padding:0;">

    <content>
        <ScrollPane fitToWidth="true" style="-fx-background:transparent;-fx-background-color:transparent;" maxHeight="700">
            <VBox spacing="0" style="-fx-background-color:#F8FAFC;">

                <!-- ══ HEADER ════════════════════════════════════════════ -->
                <VBox style="-fx-background-color:linear-gradient(to right,#4F46E5,#7C3AED);-fx-padding:20 24 20 24;">
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="🤖" style="-fx-font-size:28px;-fx-background-color:rgba(255,255,255,0.2);-fx-background-radius:50;-fx-padding:8 10 8 10;"/>
                        <VBox spacing="3">
                            <Label text="Génération de tâches par IA" style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                            <Label text="Propulsé par Groq AI (LLaMA 3) — 100% gratuit" style="-fx-font-size:11px;-fx-text-fill:rgba(255,255,255,0.75);"/>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label style="-fx-background-color:rgba(255,255,255,0.2);-fx-text-fill:white;-fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:20;-fx-padding:4 10 4 10;" text="⚡ Groq AI — Gratuit"/>
                    </HBox>
                </VBox>

                <!-- ══ OBJECTIF TITRE ══════════════════════════════════════ -->
                <VBox style="-fx-background-color:#FFFFFF;-fx-padding:16 24 16 24;-fx-border-color:#E2E8F0;-fx-border-width:0 0 1 0;">
                    <Label fx:id="lblObjectifTitre" text="📋  Objectif" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;-fx-wrap-text:true;" wrapText="true"/>
                </VBox>

                <!-- ══ STATS GRID ═══════════════════════════════════════════ -->
                <HBox spacing="10" style="-fx-padding:16 24 0 24;">
                    <VBox style="-fx-background-color:#FFFFFF;-fx-background-radius:12;-fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:12;-fx-padding:12 16 12 16;-fx-alignment:CENTER;" HBox.hgrow="ALWAYS">
                        <Label text="📋" style="-fx-font-size:16px;"/>
                        <Label fx:id="statTotal" text="—" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        <Label text="Total objectifs" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
                    </VBox>
                    <VBox style="-fx-background-color:#FFFFFF;-fx-background-radius:12;-fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:12;-fx-padding:12 16 12 16;-fx-alignment:CENTER;" HBox.hgrow="ALWAYS">
                        <Label text="✓" style="-fx-font-size:16px;-fx-text-fill:#10B981;"/>
                        <Label fx:id="statCompletion" text="—" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        <Label text="Taux complétion" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
                    </VBox>
                    <VBox style="-fx-background-color:#FFFFFF;-fx-background-radius:12;-fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:12;-fx-padding:12 16 12 16;-fx-alignment:CENTER;" HBox.hgrow="ALWAYS">
                        <Label text="⚡" style="-fx-font-size:16px;-fx-text-fill:#F59E0B;"/>
                        <Label fx:id="statTerminees" text="—" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        <Label text="Tâches terminées" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
                    </VBox>
                    <VBox style="-fx-background-color:#FFFFFF;-fx-background-radius:12;-fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:12;-fx-padding:12 16 12 16;-fx-alignment:CENTER;" HBox.hgrow="ALWAYS">
                        <Label text="⏰" style="-fx-font-size:16px;-fx-text-fill:#EF4444;"/>
                        <Label fx:id="statBloquees" text="—" style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        <Label text="Tâches bloquées" style="-fx-font-size:10px;-fx-text-fill:#94A3B8;"/>
                    </VBox>
                </HBox>

                <!-- ══ PANEL READY ══════════════════════════════════════════ -->
                <VBox fx:id="panelReady" spacing="16" style="-fx-padding:20 24 24 24;" alignment="CENTER">
                    <Label text="🤖" style="-fx-font-size:52px;"/>
                    <Label text="Prêt à analyser votre progression" style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                    <Label text="L'IA va analyser votre objectif et votre historique pour proposer 3 tâches personnalisées."
                           style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-wrap-text:true;-fx-alignment:CENTER;" wrapText="true" textAlignment="CENTER"/>

                    <Button fx:id="btnGenerer" text="✨  Générer mes tâches personnalisées" maxWidth="Infinity"
                            onAction="#handleGenerer"
                            style="-fx-background-color:#4F46E5;-fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;-fx-background-radius:10;-fx-padding:12 0 12 0;-fx-cursor:hand;"/>

                    <Label text="⚡ Propulsé par Groq AI (LLaMA 3) — 100% gratuit"
                           style="-fx-font-size:11px;-fx-text-fill:#94A3B8;"/>
                </VBox>

                <!-- ══ PANEL LOADING ════════════════════════════════════════ -->
                <VBox fx:id="panelLoading" spacing="14" style="-fx-padding:40 24 40 24;" alignment="CENTER" visible="false" managed="false">
                    <Label text="🤖" style="-fx-font-size:52px;"/>
                    <ProgressIndicator style="-fx-pref-width:40;-fx-pref-height:40;-fx-progress-color:#4F46E5;"/>
                    <Label fx:id="lblLoadingMsg" text="🤖 L'IA analyse votre profil..."
                           style="-fx-font-size:13px;-fx-text-fill:#64748B;-fx-font-weight:bold;"/>
                </VBox>

                <!-- ══ PANEL RESULTS ════════════════════════════════════════ -->
                <VBox fx:id="panelResults" spacing="0" visible="false" managed="false">
                    <HBox style="-fx-padding:16 24 12 24;" alignment="CENTER_LEFT" spacing="10">
                        <Label text="⭐  3 Tâches recommandées"
                               style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnRegenerer" text="↺  Régénérer" onAction="#handleRegenerer"
                                style="-fx-background-color:#EEF2FF;-fx-text-fill:#4F46E5;-fx-font-size:11px;-fx-font-weight:bold;-fx-background-radius:8;-fx-padding:6 14 6 14;-fx-cursor:hand;"/>
                        <Button fx:id="btnRetour" text="← Retour" onAction="#handleRetour"
                                style="-fx-background-color:#F1F5F9;-fx-text-fill:#64748B;-fx-font-size:11px;-fx-background-radius:8;-fx-padding:6 14 6 14;-fx-cursor:hand;"/>
                    </HBox>

                    <VBox fx:id="cardsContainer" spacing="12" style="-fx-padding:0 24 24 24;"/>
                </VBox>

                <!-- ══ PANEL ERROR ══════════════════════════════════════════ -->
                <VBox fx:id="panelError" spacing="14" style="-fx-padding:30 24 30 24;-fx-alignment:CENTER;" alignment="CENTER" visible="false" managed="false">
                    <Label text="❌" style="-fx-font-size:40px;"/>
                    <Label text="Erreur de génération" style="-fx-font-size:14px;-fx-font-weight:bold;-fx-text-fill:#E11D48;"/>
                    <Label fx:id="lblErrorMsg" text="Vérifiez votre clé API."
                           style="-fx-font-size:12px;-fx-text-fill:#64748B;-fx-wrap-text:true;" wrapText="true" textAlignment="CENTER"/>
                    <Button text="↺  Réessayer" onAction="#handleRetour"
                            style="-fx-background-color:#4F46E5;-fx-text-fill:white;-fx-font-size:12px;-fx-font-weight:bold;-fx-background-radius:8;-fx-padding:9 24 9 24;-fx-cursor:hand;"/>
                </VBox>

            </VBox>
        </ScrollPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="CLOSE"/>
    </buttonTypes>

</DialogPane>
