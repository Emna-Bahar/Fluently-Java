<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.PerformanceAnalyzerController"
      spacing="20"
      style="-fx-background-color:#F5F7FF;-fx-padding:30;">

    <!-- En-tête -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Label text="📊 Analyse de Performance"
               style="-fx-font-size:26px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="langueComboBox" prefWidth="180"
                  style="-fx-background-radius:10;-fx-font-size:14px;"/>
        <ProgressIndicator fx:id="loadingIndicator"
                           prefWidth="30" prefHeight="30" visible="false"/>
    </HBox>

    <!-- 5 Cartes statistiques -->
    <HBox spacing="12">
        <!-- Tests Passés -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
            <Label text="Tests Passés"
                   style="-fx-text-fill:#8A8FA8;-fx-font-size:12px;"/>
            <Label fx:id="testsPassesLabel" text="0"
                   style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#6C63FF;"/>
        </VBox>
        <!-- Score Moyen -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
            <Label text="Score Moyen"
                   style="-fx-text-fill:#8A8FA8;-fx-font-size:12px;"/>
            <Label fx:id="scoreMoyenLabel" text="0%"
                   style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#059669;"/>
        </VBox>
        <!-- Meilleur Score -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
            <Label text="Meilleur Score"
                   style="-fx-text-fill:#8A8FA8;-fx-font-size:12px;"/>
            <Label fx:id="meilleurScoreLabel" text="0%"
                   style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#F59E0B;"/>
        </VBox>
        <!-- Dernier Score -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
            <Label text="Dernier Score"
                   style="-fx-text-fill:#8A8FA8;-fx-font-size:12px;"/>
            <Label fx:id="dernierScoreLabel" text="0%"
                   style="-fx-font-size:32px;-fx-font-weight:bold;-fx-text-fill:#3B82F6;"/>
        </VBox>
        <!-- Progression -->
        <VBox HBox.hgrow="ALWAYS" alignment="CENTER" spacing="6"
              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:18;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
            <Label text="Progression"
                   style="-fx-text-fill:#8A8FA8;-fx-font-size:12px;"/>
            <Label fx:id="progressionLabel" text="—"
                   style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:#6B7280;"/>
        </VBox>
    </HBox>

    <!-- Corps principal -->
    <HBox spacing="20" VBox.vgrow="ALWAYS">

        <!-- Colonne gauche : Compétences -->
        <VBox prefWidth="300" spacing="12"
              style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:22;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
            <Label text="🎯 Compétences"
                   style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <VBox fx:id="competencesContainer" spacing="10" VBox.vgrow="ALWAYS"/>
        </VBox>

        <!-- Colonne droite : Graphique + Recommandations -->
        <VBox HBox.hgrow="ALWAYS" spacing="18">

            <!-- Graphique évolution -->
            <VBox style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:22;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
                <Label text="📈 Évolution du Score"
                       style="-fx-font-size:16px;-fx-font-weight:bold;
                              -fx-text-fill:#1A1D2E;-fx-padding:0 0 8 0;"/>
                <LineChart fx:id="progressionChart" prefHeight="200"
                           animated="false" legendVisible="false">
                    <xAxis>
                        <CategoryAxis label="Date"/>
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Score %" lowerBound="0"
                                    upperBound="100" tickUnit="20" autoRanging="false"/>
                    </yAxis>
                </LineChart>
            </VBox>

            <!-- Recommandations IA -->
            <VBox VBox.vgrow="ALWAYS" spacing="10"
                  style="-fx-background-color:white;-fx-background-radius:14;-fx-padding:22;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),10,0,0,2);">
                <Label text="🤖 Recommandations IA"
                       style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                <Label fx:id="messageEncouragementLabel" text=""
                       style="-fx-font-size:13px;-fx-text-fill:#6C63FF;-fx-font-style:italic;"/>
                <TextArea fx:id="recommendationsArea"
                          editable="false" wrapText="true"
                          prefHeight="150"
                          style="-fx-background-radius:10;-fx-font-size:13px;
                                 -fx-background-color:#F8F9FF;"/>
            </VBox>
        </VBox>
    </HBox>
</VBox>