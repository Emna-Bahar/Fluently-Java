<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.MesTestsController"
      spacing="0" style="-fx-background-color:#F8F9FD;">

    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white;-fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">
        <padding><Insets top="24" left="32" right="32" bottom="24"/></padding>
        <VBox HBox.hgrow="ALWAYS" spacing="4">
            <Label text="📝 Mes Tests"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <Label text="Choisissez un test QCM à passer"
                   style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>
        </VBox>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;">
        <VBox spacing="16">
            <padding><Insets top="32" left="48" right="48" bottom="32"/></padding>

            <!-- Grille des tests -->
            <FlowPane fx:id="flowTests" hgap="20" vgap="20"
                      prefWrapLength="900"/>
        </VBox>
    </ScrollPane>
</VBox>