<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            style="-fx-background:#F1F5F9;-fx-background-color:#F1F5F9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.TacheController">

    <VBox spacing="20" style="-fx-padding:24 28 28 28;-fx-background-color:#F1F5F9;">

        <!-- En-tête -->
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:linear-gradient(to right,#3B82F6,#6C63FF);
                     -fx-background-radius:18;-fx-padding:22 26 22 26;
                     -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.35),24,0,0,8);">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label fx:id="pageTitle" text="📋  Tâches"
                       style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label fx:id="pageSubtitle" text="Kanban — Glissez vos tâches pour changer leur statut"
                       style="-fx-font-size:11px;-fx-text-fill:rgba(255,255,255,0.78);"/>
            </VBox>
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Label fx:id="countLabel" text="0 tâche(s)"
                       style="-fx-background-color:rgba(255,255,255,0.20);-fx-text-fill:white;
                              -fx-font-size:12px;-fx-font-weight:bold;
                              -fx-background-radius:30;-fx-padding:6 14 6 14;"/>
                <Button text="← Retour" onAction="#handleRetour"
                        style="-fx-background-color:rgba(255,255,255,0.18);-fx-text-fill:white;
                               -fx-font-size:12px;-fx-font-weight:bold;
                               -fx-background-radius:10;-fx-padding:7 14 7 14;-fx-cursor:hand;
                               -fx-border-color:rgba(255,255,255,0.35);-fx-border-width:1;-fx-border-radius:10;"/>
            </HBox>
        </HBox>

        <!-- Barre recherche + Ajouter -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="380"
                  style="-fx-background-color:#FFFFFF;-fx-background-radius:11;
                         -fx-border-color:#E2E8F0;-fx-border-radius:11;-fx-border-width:1.5;
                         -fx-padding:9 14 9 14;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                <Label text="🔍" style="-fx-font-size:13px;-fx-text-fill:#9CA3AF;"/>
                <TextField fx:id="searchField"
                           promptText="Rechercher par titre, statut, priorité…"
                           onKeyReleased="#handleSearch"
                           style="-fx-background-color:transparent;-fx-border-color:transparent;
                                  -fx-font-size:12px;-fx-text-fill:#374151;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
            <Button fx:id="btnAjouter" text="✚  Ajouter une tâche" onAction="#handleAjouter"
                    style="-fx-background-color:linear-gradient(to right,#3B82F6,#6C63FF);
                           -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                           -fx-background-radius:11;-fx-padding:10 18 10 18;-fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),12,0,0,4);"/>
        </HBox>

        <!-- Formulaire -->
        <VBox fx:id="formCard" spacing="16" visible="false" managed="false"
              style="-fx-background-color:#FFFFFF;-fx-background-radius:16;
                     -fx-border-color:#E2E8F0;-fx-border-radius:16;-fx-border-width:1.5;
                     -fx-padding:22;
                     -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.10),18,0,0,5);">

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="formTitleIcon" text="✚" style="-fx-font-size:18px;-fx-text-fill:#3B82F6;"/>
                <Label fx:id="formTitle" text="Nouvelle Tâche" style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            </HBox>

            <Separator/>

            <HBox spacing="14">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Titre * (3-50 caractères)" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldTitre" promptText="Ex : Lire le chapitre 3"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-padding:9 12 9 12;-fx-font-size:13px;"/>
                    <Label fx:id="errTitre" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" prefWidth="160">
                    <Label text="Priorité *" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboPriorite" promptText="Choisir…" maxWidth="Infinity"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                    <Label fx:id="errPriorite" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" prefWidth="160">
                    <Label text="Statut *" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboStatut" promptText="Choisir…" maxWidth="Infinity"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                    <Label fx:id="errStatut" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <VBox spacing="4" maxWidth="250">
                <Label text="Date limite *" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                <DatePicker fx:id="fieldDateLimite" maxWidth="Infinity"
                            style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                   -fx-border-radius:10;-fx-background-radius:10;"/>
                <Label fx:id="errDateLimite" text="" visible="false" managed="false"
                       style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Description * (max 100 caractères)" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                <TextArea fx:id="fieldDescription" promptText="Décrivez la tâche…"
                          prefRowCount="3" wrapText="true"
                          style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                 -fx-border-radius:10;-fx-background-radius:10;
                                 -fx-padding:9 12 9 12;-fx-font-size:13px;"/>
                <Label fx:id="errDescription" text="" visible="false" managed="false"
                       style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
            </VBox>

            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Langue du texte" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboLangue" maxWidth="Infinity"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-padding:9 12 9 12;
                                     -fx-font-size:12px;"/>
                </VBox>
                <VBox spacing="4" alignment="BOTTOM_LEFT">
                    <Label text=" " style="-fx-font-size:11px;"/>
                    <Label text="💡 Correction automatique" style="-fx-text-fill:#94A3B8; -fx-font-size:10px; -fx-font-style:italic;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button text="✕  Annuler" onAction="#handleCancel"
                        style="-fx-background-color:#F8FAFC;-fx-text-fill:#64748B;-fx-font-size:13px;
                               -fx-font-weight:bold;-fx-background-radius:10;-fx-padding:9 18 9 18;
                               -fx-cursor:hand;-fx-border-color:#E2E8F0;-fx-border-width:1.5;-fx-border-radius:10;"/>
                <Button text="💾  Enregistrer" onAction="#handleSave"
                        style="-fx-background-color:linear-gradient(to right,#3B82F6,#6C63FF);
                               -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                               -fx-background-radius:10;-fx-padding:9 18 9 18;-fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),10,0,0,3);"/>
            </HBox>
        </VBox>

        <!-- Légende priorités -->
        <HBox spacing="12" alignment="CENTER_LEFT">
            <Label text="Priorités :" style="-fx-font-size:11px;-fx-font-weight:bold;-fx-text-fill:#94A3B8;"/>
            <Label text="🔴 Urgente" style="-fx-background-color:#FEE2E2;-fx-text-fill:#991B1B;
                          -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:6;-fx-padding:3 8 3 8;"/>
            <Label text="🟠 Haute" style="-fx-background-color:#FEF3C7;-fx-text-fill:#92400E;
                          -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:6;-fx-padding:3 8 3 8;"/>
            <Label text="🟡 Normale" style="-fx-background-color:#DBEAFE;-fx-text-fill:#1E40AF;
                          -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:6;-fx-padding:3 8 3 8;"/>
            <Label text="🟢 Basse" style="-fx-background-color:#DCFCE7;-fx-text-fill:#166534;
                          -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:6;-fx-padding:3 8 3 8;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="⠿ Glissez vos tâches entre les colonnes"
                   style="-fx-font-size:10px;-fx-text-fill:#CBD5E1;-fx-font-style:italic;"/>
        </HBox>

        <!-- Kanban Board -->
        <HBox spacing="16" fillHeight="true">

            <VBox HBox.hgrow="ALWAYS" spacing="10" minWidth="200"
                  style="-fx-background-color:#F8FAFC;-fx-background-radius:16;
                         -fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:16;
                         -fx-padding:14;">
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color:#64748B18;-fx-background-radius:10;-fx-padding:8 12 8 12;">
                    <Label text="📋" style="-fx-font-size:13px;"/>
                    <Label text="À faire" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#475569;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="cntAFaire" text="0" style="-fx-background-color:#64748B;-fx-text-fill:white;
                                  -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:20;-fx-padding:2 8 2 8;"/>
                </HBox>
                <VBox fx:id="colAFaire" spacing="10" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="10" minWidth="200"
                  style="-fx-background-color:#F8FAFC;-fx-background-radius:16;
                         -fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:16;
                         -fx-padding:14;">
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color:#3B82F618;-fx-background-radius:10;-fx-padding:8 12 8 12;">
                    <Label text="🔄" style="-fx-font-size:13px;"/>
                    <Label text="En cours" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1D4ED8;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="cntEnCours" text="0" style="-fx-background-color:#3B82F6;-fx-text-fill:white;
                                  -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:20;-fx-padding:2 8 2 8;"/>
                </HBox>
                <VBox fx:id="colEnCours" spacing="10" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="10" minWidth="200"
                  style="-fx-background-color:#F8FAFC;-fx-background-radius:16;
                         -fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:16;
                         -fx-padding:14;">
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color:#10B98118;-fx-background-radius:10;-fx-padding:8 12 8 12;">
                    <Label text="✅" style="-fx-font-size:13px;"/>
                    <Label text="Terminée" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#065F46;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="cntTerminee" text="0" style="-fx-background-color:#10B981;-fx-text-fill:white;
                                  -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:20;-fx-padding:2 8 2 8;"/>
                </HBox>
                <VBox fx:id="colTerminee" spacing="10" VBox.vgrow="ALWAYS"/>
            </VBox>

            <VBox HBox.hgrow="ALWAYS" spacing="10" minWidth="200"
                  style="-fx-background-color:#F8FAFC;-fx-background-radius:16;
                         -fx-border-color:#E2E8F0;-fx-border-width:1;-fx-border-radius:16;
                         -fx-padding:14;">
                <HBox alignment="CENTER_LEFT" spacing="8"
                      style="-fx-background-color:#EF444418;-fx-background-radius:10;-fx-padding:8 12 8 12;">
                    <Label text="❌" style="-fx-font-size:13px;"/>
                    <Label text="Annulée" style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#991B1B;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="cntAnnulee" text="0" style="-fx-background-color:#EF4444;-fx-text-fill:white;
                                  -fx-font-size:10px;-fx-font-weight:bold;-fx-background-radius:20;-fx-padding:2 8 2 8;"/>
                </HBox>
                <VBox fx:id="colAnnulee" spacing="10" VBox.vgrow="ALWAYS"/>
            </VBox>

        </HBox>

    </VBox>
</ScrollPane>