<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true"
            style="-fx-background:#F1F5F9;-fx-background-color:#F1F5F9;"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.TacheController">

    <VBox spacing="22" style="-fx-padding:28 34 28 34;-fx-background-color:#F1F5F9;">

        <!-- ══ En-tête ══════════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color:linear-gradient(to right,#3B82F6,#6C63FF);
                     -fx-background-radius:18;-fx-padding:24 28 24 28;
                     -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.35),24,0,0,8);">
            <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="pageTitle" text="📋  Tâches"
                       style="-fx-font-size:24px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                <Label fx:id="pageSubtitle" text="Gérez les tâches de cet objectif"
                       style="-fx-font-size:12px;-fx-text-fill:rgba(255,255,255,0.78);"/>
            </VBox>
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Label fx:id="countLabel" text="0 tâche(s)"
                       style="-fx-background-color:rgba(255,255,255,0.20);-fx-text-fill:white;
                              -fx-font-size:12px;-fx-font-weight:bold;
                              -fx-background-radius:30;-fx-padding:7 16 7 16;"/>
                <Button text="← Retour aux objectifs" onAction="#handleRetour"
                        style="-fx-background-color:rgba(255,255,255,0.18);-fx-text-fill:white;
                               -fx-font-size:12px;-fx-font-weight:bold;
                               -fx-background-radius:10;-fx-padding:8 16 8 16;-fx-cursor:hand;
                               -fx-border-color:rgba(255,255,255,0.35);-fx-border-width:1;-fx-border-radius:10;"/>
            </HBox>
        </HBox>

        <!-- ══ Barre recherche + Ajouter ════════════════════════════ -->
        <HBox spacing="14" alignment="CENTER_LEFT">
            <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" maxWidth="420"
                  style="-fx-background-color:#FFFFFF;-fx-background-radius:12;
                         -fx-border-color:#E2E8F0;-fx-border-radius:12;-fx-border-width:1.5;
                         -fx-padding:10 16 10 16;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),8,0,0,2);">
                <Label text="🔍" style="-fx-font-size:14px;-fx-text-fill:#9CA3AF;"/>
                <TextField fx:id="searchField"
                           promptText="Rechercher par titre, statut, priorité…"
                           onKeyReleased="#handleSearch"
                           style="-fx-background-color:transparent;-fx-border-color:transparent;
                                  -fx-font-size:13px;-fx-text-fill:#374151;"
                           HBox.hgrow="ALWAYS"/>
            </HBox>
            <Button text="✚  Ajouter une tâche" onAction="#handleAjouter"
                    style="-fx-background-color:linear-gradient(to right,#3B82F6,#6C63FF);
                           -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                           -fx-background-radius:12;-fx-padding:11 20 11 20;-fx-cursor:hand;
                           -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),12,0,0,4);"/>
        </HBox>

        <!-- ══ Formulaire ════════════════════════════════════════════ -->
        <VBox fx:id="formCard" spacing="18" visible="false" managed="false"
              style="-fx-background-color:#FFFFFF;-fx-background-radius:18;
                     -fx-border-color:#E2E8F0;-fx-border-radius:18;-fx-border-width:1.5;
                     -fx-padding:26;
                     -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.10),20,0,0,6);">

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="formTitleIcon" text="✚"
                       style="-fx-font-size:20px;-fx-text-fill:#3B82F6;"/>
                <Label fx:id="formTitle" text="Nouvelle Tâche"
                       style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#1E293B;"/>
            </HBox>

            <Separator style="-fx-background-color:#F1F5F9;"/>

            <!-- Titre + Priorité + Statut -->
            <HBox spacing="16">
                <VBox spacing="4" HBox.hgrow="ALWAYS">
                    <Label text="Titre * (3 à 50 caractères)"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <TextField fx:id="fieldTitre" promptText="Ex : Lire le chapitre 3"
                               style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                      -fx-border-radius:10;-fx-background-radius:10;
                                      -fx-padding:10 13 10 13;-fx-font-size:13px;-fx-text-fill:#1E293B;"/>
                    <Label fx:id="errTitre" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" prefWidth="175">
                    <Label text="Priorité *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboPriorite" promptText="Choisir…" maxWidth="Infinity"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                    <Label fx:id="errPriorite" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
                <VBox spacing="4" prefWidth="175">
                    <Label text="Statut *"
                           style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                    <ComboBox fx:id="comboStatut" promptText="Choisir…" maxWidth="Infinity"
                              style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                     -fx-border-radius:10;-fx-background-radius:10;-fx-font-size:13px;"/>
                    <Label fx:id="errStatut" text="" visible="false" managed="false"
                           style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
                </VBox>
            </HBox>

            <!-- Date limite -->
            <VBox spacing="4" maxWidth="280">
                <Label text="Date limite *"
                       style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                <DatePicker fx:id="fieldDateLimite" maxWidth="Infinity"
                            style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                   -fx-border-radius:10;-fx-background-radius:10;"/>
                <Label fx:id="errDateLimite" text="" visible="false" managed="false"
                       style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
            </VBox>

            <!-- Description -->
            <VBox spacing="4">
                <Label text="Description * (max 100 caractères)"
                       style="-fx-font-size:12px;-fx-font-weight:bold;-fx-text-fill:#64748B;"/>
                <TextArea fx:id="fieldDescription" promptText="Décrivez la tâche…"
                          prefRowCount="3" wrapText="true"
                          style="-fx-background-color:#F8FAFC;-fx-border-color:#E2E8F0;
                                 -fx-border-radius:10;-fx-background-radius:10;
                                 -fx-padding:10 13 10 13;-fx-font-size:13px;-fx-text-fill:#1E293B;"/>
                <Label fx:id="errDescription" text="" visible="false" managed="false"
                       style="-fx-font-size:11px;-fx-text-fill:#E11D48;-fx-font-weight:bold;"/>
            </VBox>

            <!-- Boutons -->
            <HBox spacing="12" alignment="CENTER_RIGHT">
                <Button text="✕  Annuler" onAction="#handleCancel"
                        style="-fx-background-color:#F8FAFC;-fx-text-fill:#64748B;-fx-font-size:13px;
                               -fx-font-weight:bold;-fx-background-radius:10;-fx-padding:10 20 10 20;
                               -fx-cursor:hand;-fx-border-color:#E2E8F0;-fx-border-width:1.5;-fx-border-radius:10;"/>
                <Button text="💾  Enregistrer" onAction="#handleSave"
                        style="-fx-background-color:linear-gradient(to right,#3B82F6,#6C63FF);
                               -fx-text-fill:white;-fx-font-size:13px;-fx-font-weight:bold;
                               -fx-background-radius:10;-fx-padding:10 20 10 20;-fx-cursor:hand;
                               -fx-effect:dropshadow(gaussian,rgba(59,130,246,0.4),10,0,0,3);"/>
            </HBox>
        </VBox>

        <!-- ══ Grille de cartes tâches ═══════════════════════════════ -->
        <FlowPane fx:id="cardsContainer"
                  hgap="18" vgap="18"
                  style="-fx-background-color:transparent;"
                  prefWrapLength="900"/>

    </VBox>
</ScrollPane>