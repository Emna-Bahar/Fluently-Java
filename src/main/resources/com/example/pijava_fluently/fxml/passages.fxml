<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.TestPassageController"
      spacing="0" style="-fx-background-color:#F8F9FD;">

    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white;-fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;">
        <padding><Insets top="20" left="32" right="32" bottom="20"/></padding>
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="📊 Passages de Tests"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <Label text="Consultez les passages de tests des étudiants (lecture seule)"
                   style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
        </VBox>
        <!-- Pas de bouton Ajouter : lecture seule -->
        <Label text="🔒 Lecture seule"
               style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;-fx-background-color:#F4F5FA;-fx-background-radius:8;-fx-padding:6 12;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;">
        <VBox spacing="20">
            <padding><Insets top="28" left="32" right="32" bottom="28"/></padding>

            <!-- TABLE -->
            <VBox spacing="0"
                  style="-fx-background-color:white;-fx-background-radius:16;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),16,0,0,4);">
                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding:18 24;-fx-border-color:#F0F1F7;-fx-border-width:0 0 1 0;">
                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                        <Label text="📊 Historique des Passages"
                               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                        <Label fx:id="countLabel" text="0 passage(s)"
                               style="-fx-font-size:11px;-fx-text-fill:#8A8FA8;"/>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="8"
                          style="-fx-background-color:#F4F5FA;-fx-background-radius:10;-fx-padding:8 14;-fx-border-color:#E0E3F0;-fx-border-radius:10;"
                          prefWidth="280">
                        <Label text="🔍" style="-fx-font-size:13px;"/>
                        <TextField fx:id="searchField"
                                   promptText="Rechercher par statut, user, test…"
                                   HBox.hgrow="ALWAYS" onKeyReleased="#handleSearch"
                                   style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-font-size:13px;-fx-padding:0;"/>
                    </HBox>
                </HBox>
                <TableView fx:id="tablePassages" VBox.vgrow="ALWAYS" prefHeight="500"
                           style="-fx-background-color:transparent;-fx-border-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colId"        text="#"         prefWidth="60"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colTest"      text="Test"      prefWidth="110" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colUser"      text="Étudiant"  prefWidth="110" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colScore"     text="Score"     prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colScoreMax"  text="/ Max"     prefWidth="70"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colStatut"    text="Statut"    prefWidth="150" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colTemps"     text="Temps"     prefWidth="100" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colDateDebut" text="Date"      prefWidth="110" style="-fx-alignment:CENTER;"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="10">
                            <padding><Insets top="40" bottom="40"/></padding>
                            <Label text="📭" style="-fx-font-size:48px;"/>
                            <Label text="Aucun passage trouvé"
                                   style="-fx-font-size:14px;-fx-text-fill:#8A8FA8;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>