<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.TestPassageController"
      spacing="0" style="-fx-background-color:#F0F2FF;">

    <HBox alignment="CENTER_LEFT" spacing="16"
          style="-fx-background-color:white;
                 -fx-border-color:#E8EAF0;-fx-border-width:0 0 1 0;
                 -fx-effect:dropshadow(gaussian,rgba(108,99,255,0.07),10,0,0,3);">
        <padding><Insets top="22" left="32" right="32" bottom="22"/></padding>
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="📊 Passages de Tests"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
            <Label text="Consultez les résultats des passages de tests des étudiants"
                   style="-fx-font-size:12px;-fx-text-fill:#8A8FA8;"/>
        </VBox>
        <Label text="🔒 Lecture seule"
               style="-fx-font-size:12px;-fx-text-fill:#6C63FF;
                      -fx-background-color:#F0EEFF;-fx-background-radius:20;
                      -fx-padding:6 14;-fx-font-weight:bold;"/>
    </HBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                style="-fx-background:transparent;-fx-background-color:transparent;">
        <VBox spacing="24">
            <padding><Insets top="28" left="32" right="32" bottom="32"/></padding>

            <VBox spacing="0"
                  style="-fx-background-color:white;-fx-background-radius:18;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.07),16,0,0,4);">

                <HBox alignment="CENTER_LEFT" spacing="12"
                      style="-fx-padding:18 24;-fx-border-color:#F0F1F7;
                             -fx-border-width:0 0 1 0;">
                    <VBox HBox.hgrow="ALWAYS" spacing="2">
                        <Label text="📊 Historique des Passages"
                               style="-fx-font-size:15px;-fx-font-weight:bold;
                                      -fx-text-fill:#1A1D2E;"/>
                        <Label fx:id="countLabel" text="0 passage(s)"
                               style="-fx-font-size:11px;-fx-text-fill:#8A8FA8;"/>
                    </VBox>
                    <HBox alignment="CENTER_LEFT" spacing="8" prefWidth="290"
                          style="-fx-background-color:#F4F5FA;-fx-background-radius:30;
                                 -fx-padding:9 16;-fx-border-color:#E0E3F0;
                                 -fx-border-radius:30;-fx-border-width:1;">
                        <Label text="🔍" style="-fx-font-size:13px;-fx-text-fill:#8A8FA8;"/>
                        <TextField fx:id="searchField"
                                   promptText="Rechercher par statut, user, test…"
                                   HBox.hgrow="ALWAYS" onKeyReleased="#handleSearch"
                                   style="-fx-background-color:transparent;
                                          -fx-border-color:transparent;
                                          -fx-font-size:13px;-fx-padding:0;"/>
                    </HBox>
                </HBox>

                <TableView fx:id="tablePassages" VBox.vgrow="ALWAYS" prefHeight="500"
                           style="-fx-background-color:transparent;
                                  -fx-border-color:transparent;">
                    <columns>
                        <TableColumn fx:id="colId"        text="#"
                                     prefWidth="60"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colTest"      text="Test"
                                     prefWidth="180" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colUser"      text="Étudiant"
                                     prefWidth="100" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colScore"     text="Score"
                                     prefWidth="80"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colScoreMax"  text="/ Max"
                                     prefWidth="70"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colStatut"    text="Statut"
                                     prefWidth="140" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colTemps"     text="Temps"
                                     prefWidth="90"  style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colDateDebut" text="Date"
                                     prefWidth="100" style="-fx-alignment:CENTER;"/>
                        <TableColumn fx:id="colActions"   text="Actions"
                                     prefWidth="140" style="-fx-alignment:CENTER;"/>
                    </columns>
                    <placeholder>
                        <VBox alignment="CENTER" spacing="12">
                            <padding><Insets top="50" bottom="50"/></padding>
                            <Label text="📭" style="-fx-font-size:52px;"/>
                            <Label text="Aucun passage trouvé"
                                   style="-fx-font-size:15px;-fx-font-weight:bold;
                                          -fx-text-fill:#4A4D6A;"/>
                            <Label text="Les passages apparaîtront ici après les tests"
                                   style="-fx-font-size:12px;-fx-text-fill:#C0C4D8;"/>
                        </VBox>
                    </placeholder>
                </TableView>
            </VBox>
        </VBox>
    </ScrollPane>
</VBox>