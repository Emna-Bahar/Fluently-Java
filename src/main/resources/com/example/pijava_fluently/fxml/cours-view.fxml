<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.CoursController"
      spacing="20" styleClass="content-area">
    <padding><Insets top="32" left="32" right="32" bottom="32"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="📚 Gestion des Cours" styleClass="page-title" HBox.hgrow="ALWAYS"/>
        <Button text="＋ Ajouter" styleClass="btn-primary" onAction="#handleAjouter"/>
    </HBox>

    <VBox fx:id="formCard" styleClass="table-card" spacing="16" visible="false" managed="false">
        <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
        <Label fx:id="formTitle" text="Nouveau Cours" styleClass="table-title"/>
        <GridPane hgap="16" vgap="12">
            <TextField fx:id="fieldNumero"    promptText="Numéro"          GridPane.columnIndex="0" GridPane.rowIndex="0" prefWidth="200"/>
            <TextField fx:id="fieldRessource" promptText="Ressource (url)" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="200"/>
            <DatePicker fx:id="fieldDate"     promptText="Date création"   GridPane.columnIndex="0" GridPane.rowIndex="1" prefWidth="200"/>
            <ComboBox   fx:id="comboNiveau"   promptText="Niveau"          GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="200"/>
            <ComboBox   fx:id="comboPrecedent" promptText="Cours précédent (optionnel)" GridPane.columnIndex="0" GridPane.rowIndex="2" prefWidth="200"/>
        </GridPane>
        <HBox spacing="10">
            <Button text="💾 Enregistrer" styleClass="btn-primary" onAction="#handleSave"/>
            <Button text="Annuler"         styleClass="btn-secondary" onAction="#handleCancel"/>
        </HBox>
    </VBox>

    <VBox styleClass="table-card" VBox.vgrow="ALWAYS">
        <HBox styleClass="table-header" alignment="CENTER_LEFT">
            <padding><Insets top="14" left="20" right="20" bottom="14"/></padding>
            <Label text="Liste des Cours" styleClass="table-title" HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="🔍 Rechercher..." prefWidth="220"
                       onKeyReleased="#handleSearch"/>
        </HBox>
        <TableView fx:id="tableCours" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId"        text="ID"        prefWidth="50"/>
                <TableColumn fx:id="colNumero"    text="N°"        prefWidth="60"/>
                <TableColumn fx:id="colRessource" text="Ressource" prefWidth="200"/>
                <TableColumn fx:id="colDate"      text="Date"      prefWidth="120"/>
                <TableColumn fx:id="colNiveau"    text="Niveau"    prefWidth="120"/>
                <TableColumn fx:id="colPrecedent" text="Précédent" prefWidth="100"/>
                <TableColumn fx:id="colActions"   text="Actions"   prefWidth="160"/>
            </columns>
        </TableView>
    </VBox>
</VBox>