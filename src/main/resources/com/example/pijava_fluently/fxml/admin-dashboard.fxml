<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.AdminDashboardController"
            prefWidth="1280" prefHeight="800"
            styleClass="admin-root">

    <left>
        <VBox styleClass="sidebar" prefWidth="260" spacing="0">

            <!-- Logo -->
            <HBox styleClass="sidebar-logo" spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                <Label text="🎓" styleClass="sidebar-logo-icon"/>
                <VBox>
                    <Label text="Fluently" styleClass="sidebar-logo-name"/>
                    <Label text="Administration" styleClass="sidebar-logo-sub"/>
                </VBox>
            </HBox>

            <Separator/>

            <Label text="NAVIGATION" styleClass="nav-section-label">
                <padding><Insets top="16" left="20" right="20" bottom="6"/></padding>
            </Label>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
                <VBox spacing="2">
                    <padding><Insets top="4" left="8" right="8" bottom="8"/></padding>

                    <!-- Utilisateurs -->
                    <Button fx:id="navEtudiants" text="👥  Utilisateurs"
                            styleClass="nav-btn" maxWidth="Infinity"
                            onAction="#showEtudiants"/>

                    <!-- Langues — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navLanguesToggle" text="🌍  Langues  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleLangues"/>
                        <VBox fx:id="languesSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button text="• Langues"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showLangues"/>
                            <Button text="• Niveaux"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showNiveaux"/>
                            <Button text="• Cours"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showCours"/>
                            <Button fx:id="navUserProgress" text="• Progression"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showUserProgress"/>
                        </VBox>
                    </VBox>

                    <!-- Tests — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navTestsToggle" text="📝  Tests  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleTests"/>
                        <VBox fx:id="testsSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button text="• Tests"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showTests"/>
                            <Button text="• Questions"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showQuestions"/>
                            <Button text="• Réponses"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showReponses"/>
                            <Button text="• Passage de tests"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showPassages"/>
                        </VBox>
                    </VBox>

                    <!-- Groupes -->
                    <Button fx:id="navGroupes" text="💬  Groupes"
                            styleClass="nav-btn" maxWidth="Infinity"
                            onAction="#showGroupes"/>

                    <!-- Sessions — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navSessionsToggle" text="📅  Sessions  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleSessions"/>
                        <VBox fx:id="sessionsSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button text="• Liste Sessions"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showSessions"/>
                            <Button text="• Réservations"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showReservations"/>
                        </VBox>
                    </VBox>

                    <!-- Objectifs — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navObjectifsToggle" text="🎯  Objectifs  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleObjectifs"/>
                        <VBox fx:id="objectifsSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button text="• Objectifs"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showObjectifs"/>
                            <Button text="• Tâches"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showTaches"/>
                        </VBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Profile bas -->
            <Separator/>
            <HBox spacing="12" alignment="CENTER_LEFT">
                <padding><Insets top="14" left="16" right="16" bottom="16"/></padding>
                <Label text="👤" styleClass="profile-avatar"/>
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="adminName" text="Admin" styleClass="profile-name"/>
                    <Label text="Administrateur" styleClass="profile-role"/>
                </VBox>
                <Button text="⏻" styleClass="logout-btn" onAction="#handleLogout">
                    <tooltip><Tooltip text="Se déconnecter"/></tooltip>
                </Button>
            </HBox>

        </VBox>
    </left>

    <center>
        <VBox styleClass="main-content">

            <!-- Topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="0" left="32" right="32" bottom="0"/></padding>
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="pageTitle" text="Dashboard" styleClass="page-title"/>
                    <Label fx:id="pageBreadcrumb" text="Administration › Dashboard" styleClass="page-breadcrumb"/>
                </VBox>
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="🔔" styleClass="icon-btn"/>
                    <HBox styleClass="topbar-user" spacing="8" alignment="CENTER">
                        <Label text="👤" styleClass="topbar-avatar"/>
                        <Label fx:id="topbarUsername" text="Admin" styleClass="topbar-username"/>
                        <Label text="▾" styleClass="topbar-arrow"/>
                    </HBox>
                </HBox>
            </HBox>

            <!-- Zone de contenu — toutes les vues empilées -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="content-scroll">
                <VBox styleClass="content-area" spacing="0">
                    <padding><Insets top="32" left="32" right="32" bottom="32"/></padding>

                    <!-- DASHBOARD -->
                    <VBox fx:id="dashboardView" spacing="24" visible="true" managed="true">
                        <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="20">
                            <padding><Insets top="24" left="28" right="28" bottom="24"/></padding>
                            <VBox HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Bonjour, Admin 👋" styleClass="welcome-title"/>
                                <Label text="Voici un aperçu de l'activité de Fluently." styleClass="welcome-sub"/>
                            </VBox>
                            <Label text="🎓" styleClass="welcome-icon"/>
                        </HBox>
                        <HBox spacing="16">
                            <VBox styleClass="stat-card,stat-blue" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="📝" styleClass="card-icon"/>
                                <Label fx:id="statTests" text="—" styleClass="card-value"/>
                                <Label text="Tests créés" styleClass="card-desc"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-green" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="✅" styleClass="card-icon"/>
                                <Label fx:id="statPassages" text="—" styleClass="card-value"/>
                                <Label text="Tests passés" styleClass="card-desc"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-purple" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="👥" styleClass="card-icon"/>
                                <Label fx:id="statEtudiants" text="—" styleClass="card-value"/>
                                <Label text="Utilisateurs" styleClass="card-desc"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-orange" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="📊" styleClass="card-icon"/>
                                <Label fx:id="statScore" text="—" styleClass="card-value"/>
                                <Label text="Score moyen" styleClass="card-desc"/>
                            </VBox>
                        </HBox>
                        <VBox styleClass="table-card" spacing="0">
                            <HBox styleClass="table-header" alignment="CENTER_LEFT">
                                <padding><Insets top="16" left="20" right="20" bottom="16"/></padding>
                                <Label text="Derniers passages de tests" styleClass="table-title" HBox.hgrow="ALWAYS"/>
                                <Button text="Voir tout →" styleClass="btn-link" onAction="#showPassages"/>
                            </HBox>
                            <TableView fx:id="recentPassagesTable" prefHeight="220">
                                <columns>
                                    <TableColumn fx:id="colEtudiant" text="Étudiant" prefWidth="200"/>
                                    <TableColumn fx:id="colTest"     text="Test"     prefWidth="200"/>
                                    <TableColumn fx:id="colScore"    text="Score"    prefWidth="100"/>
                                    <TableColumn fx:id="colStatut"   text="Statut"   prefWidth="120"/>
                                    <TableColumn fx:id="colDate"     text="Date"     prefWidth="150"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>

                    <!-- LANGUES — conteneur vide, rempli dynamiquement -->
                    <VBox fx:id="languesView"  visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="niveauxView"  visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="coursView"    visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="userProgressView"  visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <!-- AUTRES VUES placeholder -->
                    <VBox fx:id="etudiantsView"   visible="false" managed="false" spacing="16">
                        <Label text="👥 Gestion des Utilisateurs" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="testsView"       visible="false" managed="false" spacing="16">
                        <Label text="📝 Gestion des Tests" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="questionsView"   visible="false" managed="false" spacing="16">
                        <Label text="❓ Gestion des Questions" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="reponsesView"    visible="false" managed="false" spacing="16">
                        <Label text="✅ Gestion des Réponses" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="passagesView"    visible="false" managed="false" spacing="16">
                        <Label text="📋 Passages de Tests" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="groupesView"     visible="false" managed="false" spacing="16">
                        <Label text="💬 Gestion des Groupes" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="sessionsView"    visible="false" managed="false" spacing="16">
                        <Label text="📅 Gestion des Sessions" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="reservationsView" visible="false" managed="false" spacing="16">
                        <Label text="📅 Réservations" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="objectifsView"   visible="false" managed="false" spacing="16">
                        <Label text="🎯 Gestion des Objectifs" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>
                    <VBox fx:id="tachesView"      visible="false" managed="false" spacing="16">
                        <Label text="✔ Gestion des Tâches" styleClass="page-title"/>
                        <Label text="À implémenter" styleClass="loading-label"/>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>