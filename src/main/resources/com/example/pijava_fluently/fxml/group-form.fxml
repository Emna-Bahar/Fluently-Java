<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.GroupFormController"
      spacing="20" prefWidth="550" 
      style="-fx-background-color: white; -fx-padding: 28;">
    
    <!-- Simple Header -->
    <VBox spacing="8">
        <Label fx:id="formTitle" text="Nouveau Groupe" 
               style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #343a40;"/>
        <Label text="Remplissez les informations du groupe" 
               style="-fx-font-size: 13px; -fx-text-fill: #6c757d;"/>
    </VBox>
    
    <Separator style="-fx-background-color: #dee2e6;"/>
    
    <!-- Form Fields -->
    <VBox spacing="20">
        
        <VBox spacing="6">
            <Label text="Nom du Groupe *" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #495057;"/>
            <TextField fx:id="txtNom" promptText="Ex: English Beginners A1" 
                       style="-fx-padding: 10 12; -fx-font-size: 13px; -fx-background-radius: 6; -fx-border-color: #ced4da; -fx-border-radius: 6;"/>
        </VBox>
        
        <VBox spacing="6">
            <Label text="Description" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #495057;"/>
            <TextArea fx:id="txtDescription" 
                      promptText="Décrivez l'objectif et le contenu du groupe..." 
                      prefRowCount="3" 
                      wrapText="true"
                      style="-fx-padding: 10 12; -fx-font-size: 13px; -fx-background-radius: 6; -fx-border-color: #ced4da; -fx-border-radius: 6;"/>
        </VBox>
        
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Capacité *" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #495057;"/>
                <Spinner fx:id="spinCapacite" editable="true" prefWidth="200"/>
            </VBox>
            
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Statut *" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #495057;"/>
                <ComboBox fx:id="comboStatut" prefWidth="200"/>
            </VBox>
        </HBox>
        
        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Langue *" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #495057;"/>
                <ComboBox fx:id="comboLangue" prefWidth="200"/>
            </VBox>
            
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Niveau *" style="-fx-font-size: 13px; -fx-font-weight: 600; -fx-text-fill: #495057;"/>
                <ComboBox fx:id="comboNiveau" prefWidth="200"/>
            </VBox>
        </HBox>
        
    </VBox>
    
    <!-- Error Message -->
    <HBox fx:id="errorBox" visible="false" managed="false" spacing="8" alignment="CENTER_LEFT"
          style="-fx-background-color: #f8d7da; -fx-padding: 12 16; -fx-background-radius: 6; -fx-border-color: #f5c6cb; -fx-border-radius: 6; -fx-border-width: 1;">
        <Label text="⚠️" style="-fx-font-size: 16px;"/>
        <Label fx:id="errorLabel" text="" wrapText="true" HBox.hgrow="ALWAYS"
               style="-fx-text-fill: #721c24; -fx-font-size: 13px;"/>
    </HBox>
    
    <Separator style="-fx-background-color: #dee2e6;"/>
    
    <!-- Action Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" text="Annuler" onAction="#handleCancel"
                style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand;"/>
        <Button fx:id="btnSave" text="Enregistrer" onAction="#handleSave"
                style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-padding: 10 24; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>
    </HBox>
    
</VBox>
