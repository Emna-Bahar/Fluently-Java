<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.GroupFormController"
      spacing="20" prefWidth="550"
      style="-fx-background-color: white; -fx-padding: 28;">

    <!-- Header -->
    <VBox spacing="6">
        <Label fx:id="formTitle" text="Nouveau Groupe" styleClass="form-main-title"/>
        <Label text="Remplissez les informations du groupe"
               style="-fx-font-size: 13px; -fx-text-fill: #64748B;"/>
    </VBox>

    <Separator style="-fx-background-color: #E2E8F0;"/>

    <!-- Fields -->
    <VBox spacing="20">

        <VBox spacing="6">
            <Label text="Nom du Groupe *" styleClass="form-label"/>
            <TextField fx:id="txtNom" promptText="Ex: English Beginners A1"
                       styleClass="form-input"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Description" styleClass="form-label"/>
            <TextArea fx:id="txtDescription"
                      promptText="Décrivez l'objectif et le contenu du groupe..."
                      prefRowCount="3" wrapText="true"
                      styleClass="form-input"/>
        </VBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Capacité *" styleClass="form-label"/>
                <Spinner fx:id="spinCapacite" editable="true" prefWidth="200"
                         styleClass="form-spinner"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Statut *" styleClass="form-label"/>
                <ComboBox fx:id="comboStatut" prefWidth="200" styleClass="form-combo"/>
            </VBox>
        </HBox>

        <HBox spacing="16">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Langue *" styleClass="form-label"/>
                <ComboBox fx:id="comboLangue" prefWidth="200" styleClass="form-combo"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Niveau *" styleClass="form-label"/>
                <ComboBox fx:id="comboNiveau" prefWidth="200" styleClass="form-combo"/>
            </VBox>
        </HBox>

    </VBox>

    <!-- Error box -->
    <HBox fx:id="errorBox" visible="false" managed="false" spacing="10"
          alignment="CENTER_LEFT" styleClass="error-box">
        <Label text="⚠️" style="-fx-font-size: 16px;"/>
        <Label fx:id="errorLabel" text="" wrapText="true" HBox.hgrow="ALWAYS"
               styleClass="error-text"/>
    </HBox>

    <Separator style="-fx-background-color: #E2E8F0;"/>

    <!-- Buttons -->
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancel" text="Annuler" onAction="#handleCancel"
                styleClass="btn-cancel"/>
        <Button fx:id="btnSave" text="💾 Enregistrer" onAction="#handleSave"
                styleClass="btn-save"/>
    </HBox>

</VBox>
