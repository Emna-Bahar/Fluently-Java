<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.pijava_fluently.controller.UserProgressController"
      spacing="20" style="-fx-background-color:#F8F9FD;">

    <padding><Insets top="24" left="28" right="28" bottom="28"/></padding>

    <!-- En-tête -->
    <!-- Remplacer l'en-tête existant par -->
    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="progression-header">
        <padding><Insets top="20" left="32" right="32" bottom="20"/></padding>
        <Label text="📊" styleClass="header-icon"/>
        <VBox HBox.hgrow="ALWAYS" spacing="3">
            <Label text="Progression des Étudiants" styleClass="progression-title"/>
            <Label text="Consultez l'avancement des étudiants dans chaque langue" styleClass="page-subtitle"/>
        </VBox>
    </HBox>

    <!-- Barre de recherche et filtres -->
    <HBox spacing="16" alignment="CENTER_LEFT">
        <HBox alignment="CENTER_LEFT" spacing="8"
              style="-fx-background-color:#F4F5FA;-fx-background-radius:10;-fx-padding:8 14 8 14;"
              HBox.hgrow="ALWAYS">
            <Label text="🔍" style="-fx-font-size:14px;"/>
            <TextField fx:id="searchField" promptText="Rechercher par utilisateur, langue..."
                       HBox.hgrow="ALWAYS"
                       style="-fx-background-color:transparent;-fx-border-color:transparent;-fx-font-size:13px;-fx-padding:0;"/>
            <Button text="×" style="-fx-background-color:transparent;-fx-text-fill:#C0C4D8;-fx-cursor:hand;"
                    onAction="#clearSearch" visible="false" fx:id="clearSearchBtn"/>
        </HBox>

        <ComboBox fx:id="filterNiveau" promptText="Niveau"
                  style="-fx-background-color:#F4F5FA;-fx-background-radius:10;-fx-padding:8 14 8 14;-fx-font-size:13px;"
                  prefWidth="140"/>

        <ComboBox fx:id="filterLangue" promptText="Langue"
                  style="-fx-background-color:#F4F5FA;-fx-background-radius:10;-fx-padding:8 14 8 14;-fx-font-size:13px;"
                  prefWidth="140"/>
    </HBox>

    <!-- Tableau -->
    <VBox spacing="0"
          style="-fx-background-color:white;-fx-background-radius:16;-fx-effect:dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,2);">

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-padding:16 20 16 20;-fx-border-color:#F0F1F7;-fx-border-width:0 0 1 0;">
            <VBox HBox.hgrow="ALWAYS" spacing="2">
                <Label text="📋 Historique des Progressions"
                       style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1A1D2E;"/>
                <Label fx:id="countLabel" text="0 progression(s)" style="-fx-font-size:11px;-fx-text-fill:#8A8FA8;"/>
            </VBox>
        </HBox>

        <TableView fx:id="tableProgress" VBox.vgrow="ALWAYS" prefHeight="500"
                   style="-fx-background-color:transparent;-fx-border-color:transparent;">
            <columns>
                <TableColumn fx:id="colUserId" text=" Utilisateur" prefWidth="100" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colLangue" text=" Langue" prefWidth="140"/>
                <TableColumn fx:id="colNiveauActuel" text=" Niveau" prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDernierCours" text=" Dernier cours" prefWidth="120" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colProgression" text=" Progression" prefWidth="180"/>
                <TableColumn fx:id="colTestComplete" text=" Test niveau" prefWidth="130" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colDateActivite" text=" Dernière activité" prefWidth="160" style="-fx-alignment:CENTER;"/>
                <TableColumn fx:id="colActions" text=" Actions" prefWidth="100" style="-fx-alignment:CENTER;"/>
            </columns>
        </TableView>
    </VBox>
</VBox>