<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.collections.FXCollections?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.pijava_fluently.controller.LoginController"
           prefWidth="1000" prefHeight="680"
           styleClass="root-pane">

    <!-- Language toggle overlay -->
    <Button fx:id="btnLang" text="🌐 EN" styleClass="btn-lang"
            onAction="#toggleLanguage"
            StackPane.alignment="TOP_RIGHT"
            style="-fx-translate-x:-16; -fx-translate-y:16;"/>

    <HBox>
        <!-- Left branding panel -->
        <VBox styleClass="left-panel" HBox.hgrow="ALWAYS" prefWidth="420">
            <padding><Insets top="60" left="50" right="50" bottom="40"/></padding>
            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label text="🎓" styleClass="logo-icon"/>
                <Label text="Fluently" styleClass="logo-text"/>
            </HBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="16">
                <Label text="Learn Languages." styleClass="hero-title"/>
                <Label text="Master the World." styleClass="hero-title-accent"/>
                <Label text="Évalue ton niveau, accède à des cours personnalisés et progresse à ton rythme avec l'IA."
                       styleClass="hero-subtitle" wrapText="true"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <HBox spacing="30" alignment="CENTER_LEFT">
                <VBox styleClass="stat-box">
                    <Label text="12K+" styleClass="stat-number"/>
                    <Label text="Étudiants"   styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="8"   styleClass="stat-number"/>
                    <Label text="Langues"     styleClass="stat-label"/>
                </VBox>
                <VBox styleClass="stat-box">
                    <Label text="95%" styleClass="stat-number"/>
                    <Label text="Satisfaction" styleClass="stat-label"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- Right form panel -->
        <VBox styleClass="right-panel" HBox.hgrow="ALWAYS" prefWidth="580" alignment="CENTER">
            <padding><Insets top="50" left="70" right="70" bottom="50"/></padding>

            <!-- Tabs -->
            <HBox styleClass="tab-switcher" alignment="CENTER" spacing="0">
                <Button fx:id="loginTabBtn"    text="Connexion"       styleClass="tab-btn,tab-active"
                        onAction="#switchToLogin"    prefWidth="150"/>
                <Button fx:id="registerTabBtn" text="Créer un compte" styleClass="tab-btn"
                        onAction="#switchToRegister" prefWidth="150"/>
            </HBox>

            <Region prefHeight="35"/>

            <!-- ══ LOGIN FORM ══ -->
            <VBox fx:id="loginForm" spacing="20" visible="true" managed="true">
                <Label text="Bon retour ! 👋"                              styleClass="form-title"/>
                <Label text="Connecte-toi pour continuer ton apprentissage" styleClass="form-subtitle"/>
                <Region prefHeight="10"/>

                <VBox spacing="6">
                    <Label text="Adresse email" styleClass="field-label"/>
                    <TextField fx:id="loginEmail" promptText="exemple@email.com" styleClass="text-field"/>
                </VBox>

                <VBox spacing="6">
                    <HBox alignment="CENTER_LEFT">
                        <Label text="Mot de passe" styleClass="field-label" HBox.hgrow="ALWAYS"/>
                        <Hyperlink text="Mot de passe oublié ?" styleClass="forgot-link" onAction="#forgotPassword"/>
                    </HBox>
                    <PasswordField fx:id="loginPassword" promptText="••••••••" styleClass="text-field"/>
                </VBox>

                <Label fx:id="loginError" styleClass="error-label" visible="false" managed="false" wrapText="true"/>
                <Region prefHeight="5"/>

                <Button text="Se connecter →" styleClass="btn-primary" maxWidth="Infinity"
                        onAction="#handleLogin" defaultButton="true"/>
                <Button text="🔐 Connexion par Visage" styleClass="btn-secondary" maxWidth="Infinity"
                        onAction="#handleFaceLogin"/>

                <HBox alignment="CENTER" spacing="0">
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                    <Label text="ou" styleClass="divider-or"/>
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button fx:id="googleLoginBtn" styleClass="btn-google" maxWidth="Infinity"
                        onAction="#handleGoogleLogin">
                    <graphic>
                        <HBox alignment="CENTER" spacing="12">
                            <StackPane style="-fx-background-color:white; -fx-background-radius:2; -fx-padding:3 5 3 5;">
                                <Label text="G" style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#EA4335; -fx-font-family:'Arial';"/>
                            </StackPane>
                            <Label text="SIGN IN WITH GOOGLE" style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:white; -fx-font-family:'Segoe UI';"/>
                        </HBox>
                    </graphic>
                </Button>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Pas encore de compte ?" styleClass="switch-text"/>
                    <Hyperlink text="Créer un compte" styleClass="switch-link" onAction="#switchToRegister"/>
                </HBox>
            </VBox>

            <!-- ══ REGISTER FORM ══ -->
            <VBox fx:id="registerForm" spacing="14" visible="false" managed="false">
                <Label text="Rejoins Fluently 🚀"                              styleClass="form-title"/>
                <Label text="Commence ton voyage linguistique dès aujourd'hui" styleClass="form-subtitle"/>
                <Region prefHeight="4"/>

                <HBox spacing="15">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Prénom" styleClass="field-label"/>
                        <TextField fx:id="regPrenom" promptText="Jean" styleClass="text-field"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Nom d'utilisateur" styleClass="field-label"/>
                        <TextField fx:id="regNom" promptText="Dupont" styleClass="text-field"/>
                    </VBox>
                </HBox>

                <VBox spacing="6">
                    <Label text="Adresse email" styleClass="field-label"/>
                    <TextField fx:id="regEmail" promptText="exemple@email.com" styleClass="text-field"/>
                </VBox>

                <!-- Role selector -->
                <VBox spacing="6">
                    <Label text="Rôle" styleClass="field-label"/>
                    <HBox spacing="12">
                        <ToggleButton fx:id="btnEtudiant"  text="🎓  Étudiant"   styleClass="role-toggle"
                                      HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#selectEtudiant"/>
                        <ToggleButton fx:id="btnProf"      text="📚  Professeur" styleClass="role-toggle"
                                      HBox.hgrow="ALWAYS" maxWidth="Infinity" onAction="#selectProf"/>
                    </HBox>
                </VBox>

                <VBox spacing="6">
                    <Label text="Mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="regPassword" promptText="Min. 8 caractères" styleClass="text-field"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Confirmer le mot de passe" styleClass="field-label"/>
                    <PasswordField fx:id="regConfirmPassword" promptText="••••••••" styleClass="text-field"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="Visage (Face ID)" styleClass="field-label"/>
                    <Button text="📷 Capturer mon visage" styleClass="btn-secondary"
                            maxWidth="Infinity" onAction="#handleCaptureFace"/>
                    <Label fx:id="faceStatusLabel" visible="false" managed="false"
                           style="-fx-font-size: 12px; -fx-text-fill: #27ae60;"/>
                </VBox>

                <Label fx:id="registerError" styleClass="error-label" visible="false" managed="false" wrapText="true"/>

                <Button text="Créer mon compte →" styleClass="btn-primary" maxWidth="Infinity"
                        onAction="#handleRegister"/>

                <HBox alignment="CENTER" spacing="0">
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                    <Label text="ou" styleClass="divider-or"/>
                    <Region styleClass="divider-line" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Button styleClass="btn-google" maxWidth="Infinity"
                        onAction="#handleGoogleLogin">
                    <graphic>
                        <HBox alignment="CENTER" spacing="12">
                            <StackPane style="-fx-background-color:white; -fx-background-radius:2; -fx-padding:3 5 3 5;">
                                <Label text="G" style="-fx-font-size:15px; -fx-font-weight:bold; -fx-text-fill:#EA4335; -fx-font-family:'Arial';"/>
                            </StackPane>
                            <Label text="SIGN UP WITH GOOGLE" style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:white; -fx-font-family:'Segoe UI';"/>
                        </HBox>
                    </graphic>
                </Button>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Déjà inscrit ?" styleClass="switch-text"/>
                    <Hyperlink text="Se connecter" styleClass="switch-link" onAction="#switchToLogin"/>
                </HBox>
            </VBox>

        </VBox>
    </HBox>
</StackPane>
