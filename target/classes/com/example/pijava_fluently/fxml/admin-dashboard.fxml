<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.pijava_fluently.controller.AdminDashboardController"
            prefWidth="1280" prefHeight="800"
            styleClass="admin-root">

    <!-- ============================================================ -->
    <!-- SIDEBAR GAUCHE                                                -->
    <!-- ============================================================ -->
    <left>
        <VBox styleClass="sidebar" prefWidth="260" spacing="0">

            <!-- Logo -->
            <HBox styleClass="sidebar-logo" spacing="10" alignment="CENTER_LEFT">
                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                <Label text="🎓" styleClass="sidebar-logo-icon"/>
                <VBox>
                    <Label text="Fluently" styleClass="sidebar-logo-name"/>
                    <Label text="Administration" styleClass="sidebar-logo-sub"/>
                </VBox>
            </HBox>

            <Separator/>

            <Label text="NAVIGATION" styleClass="nav-section-label">
                <padding><Insets top="16" left="20" right="20" bottom="6"/></padding>
            </Label>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="sidebar-scroll">
                <VBox spacing="2">
                    <padding><Insets top="4" left="8" right="8" bottom="8"/></padding>

                    <!-- Utilisateurs -->
                    <Button fx:id="navEtudiants" text="👥  Utilisateurs"
                            styleClass="nav-btn" maxWidth="Infinity"
                            onAction="#showEtudiants"/>

                    <!-- Langues — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navLanguesToggle" text="🌍  Langues  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleLangues"/>
                        <VBox fx:id="languesSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button text="• Langues"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showLangues"/>
                            <Button text="• Niveaux"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showNiveaux"/>
                            <Button text="• Cours"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showCours"/>
                            <Button fx:id="navUserProgress" text="• Progression"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showUserProgress"/>
                            <Button fx:id="navLangueStats" text="• Statistiques"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showLangueStats"/>
                        </VBox>
                    </VBox>

                    <!-- Tests — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navTestsToggle" text="📝  Tests  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleTests"/>
                        <VBox fx:id="testsSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button fx:id="navTests" text="• Tests"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showTests"/>
                            <Button fx:id="navQuestions" text="• Questions"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showQuestions"/>
                            <Button fx:id="navReponses" text="• Réponses"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showReponses"/>
                            <Button fx:id="navPassages" text="• Passage de tests"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showPassages"/>
                        </VBox>
                    </VBox>

                    <!-- Groupes -->
                    <Button fx:id="navGroupes" text="💬  Groupes"
                            styleClass="nav-btn" maxWidth="Infinity"
                            onAction="#showGroupes"/>

                    <!-- Sessions — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navSessionsToggle" text="📅  Sessions  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleSessions"/>
                        <VBox fx:id="sessionsSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button fx:id="navSessionsList" text="• Liste Sessions"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showSessions"/>
                            <Button fx:id="navReservations" text="• Réservations"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showReservations"/>
                        </VBox>
                    </VBox>

                    <!-- Objectifs — menu déroulant -->
                    <VBox styleClass="nav-group">
                        <Button fx:id="navObjectifsToggle" text="🎯  Objectifs  ▾"
                                styleClass="nav-btn" maxWidth="Infinity"
                                onAction="#toggleObjectifs"/>
                        <VBox fx:id="objectifsSubmenu" visible="false" managed="false"
                              styleClass="nav-submenu" spacing="1">
                            <padding><Insets top="2" left="16" bottom="2"/></padding>
                            <Button fx:id="navObjectifsList" text="• Objectifs"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showObjectifs"/>
                            <Button fx:id="navTaches" text="• Tâches"
                                    styleClass="nav-btn-sub" maxWidth="Infinity"
                                    onAction="#showTaches"/>
                        </VBox>
                    </VBox>

                </VBox>
            </ScrollPane>

            <!-- Profile bas -->
            <Separator/>
            <HBox fx:id="topbarUserPill" spacing="12" alignment="CENTER_LEFT"
                  onMouseClicked="#showAdminUserMenu">
                <padding><Insets top="14" left="16" right="16" bottom="16"/></padding>
                <Label text="👤" styleClass="profile-avatar"/>
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="adminName" text="Admin" styleClass="profile-name"/>
                    <Label text="Administrateur" styleClass="profile-role"/>
                </VBox>
                <Button text="⏻" styleClass="logout-btn" onAction="#handleLogout">
                    <tooltip><Tooltip text="Se déconnecter"/></tooltip>
                </Button>
            </HBox>

        </VBox>
    </left>

    <!-- ============================================================ -->
    <!-- ZONE CENTRALE                                                 -->
    <!-- ============================================================ -->
    <center>
        <VBox styleClass="main-content">

            <!-- Topbar -->
            <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets top="0" left="32" right="32" bottom="0"/></padding>
                <VBox HBox.hgrow="ALWAYS">
                    <Label fx:id="pageTitle" text="Dashboard" styleClass="page-title"/>
                    <Label fx:id="pageBreadcrumb" text="Administration › Dashboard" styleClass="page-breadcrumb"/>
                </VBox>
                <HBox spacing="12" alignment="CENTER_RIGHT">
                    <Button text="🔔" styleClass="icon-btn"/>
                    <HBox fx:id="topbarUserPillRight" styleClass="topbar-user" spacing="8" alignment="CENTER"
                          onMouseClicked="#showAdminUserMenu">
                        <Label text="👤" styleClass="topbar-avatar"/>
                        <Label fx:id="topbarUsername" text="Admin" styleClass="topbar-username"/>
                        <Label text="▾" styleClass="topbar-arrow"/>
                    </HBox>
                </HBox>
            </HBox>

            <!-- Zone de contenu scrollable -->
            <ScrollPane VBox.vgrow="ALWAYS" fitToWidth="true" styleClass="content-scroll">
                <VBox styleClass="content-area" spacing="0">
                    <padding><Insets top="32" left="32" right="32" bottom="32"/></padding>

                    <!-- ═══════ DASHBOARD ═══════ -->
                    <VBox fx:id="dashboardView" spacing="24" visible="true" managed="true">
                        <HBox styleClass="welcome-banner" alignment="CENTER_LEFT" spacing="20">
                            <padding><Insets top="24" left="28" right="28" bottom="24"/></padding>
                            <VBox HBox.hgrow="ALWAYS" spacing="6">
                                <Label text="Bonjour, Admin 👋" styleClass="welcome-title"/>
                                <Label text="Voici un aperçu de l'activité de Fluently." styleClass="welcome-sub"/>
                            </VBox>
                            <Label text="🎓" styleClass="welcome-icon"/>
                        </HBox>
                        <HBox spacing="16">
                            <VBox styleClass="stat-card,stat-blue" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="📝" styleClass="card-icon"/>
                                <Label fx:id="statTests" text="—" styleClass="card-value"/>
                                <Label text="Tests créés" styleClass="card-desc"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-green" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="✅" styleClass="card-icon"/>
                                <Label fx:id="statPassages" text="—" styleClass="card-value"/>
                                <Label text="Tests passés" styleClass="card-desc"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-purple" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="👥" styleClass="card-icon"/>
                                <Label fx:id="statEtudiants" text="—" styleClass="card-value"/>
                                <Label text="Utilisateurs" styleClass="card-desc"/>
                            </VBox>
                            <VBox styleClass="stat-card,stat-orange" HBox.hgrow="ALWAYS" spacing="8">
                                <padding><Insets top="20" left="20" right="20" bottom="20"/></padding>
                                <Label text="📊" styleClass="card-icon"/>
                                <Label fx:id="statScore" text="—" styleClass="card-value"/>
                                <Label text="Score moyen" styleClass="card-desc"/>
                            </VBox>
                        </HBox>
                        <VBox styleClass="table-card" spacing="0">
                            <HBox styleClass="table-header" alignment="CENTER_LEFT">
                                <padding><Insets top="16" left="20" right="20" bottom="16"/></padding>
                                <Label text="Derniers passages de tests" styleClass="table-title" HBox.hgrow="ALWAYS"/>
                                <Button text="Voir tout →" styleClass="btn-link" onAction="#showPassages"/>
                            </HBox>
                            <TableView fx:id="recentPassagesTable" prefHeight="220">
                                <columns>
                                    <TableColumn fx:id="colEtudiant" text="Étudiant" prefWidth="200"/>
                                    <TableColumn fx:id="colTest"     text="Test"     prefWidth="200"/>
                                    <TableColumn fx:id="colScore"    text="Score"    prefWidth="100"/>
                                    <TableColumn fx:id="colStatut"   text="Statut"   prefWidth="120"/>
                                    <TableColumn fx:id="colDate"     text="Date"     prefWidth="150"/>
                                </columns>
                            </TableView>
                        </VBox>
                    </VBox>

                    <!-- ═══════ UTILISATEURS (tableau complet) ═══════ -->
                    <VBox fx:id="etudiantsView" visible="false" managed="false" spacing="24">

                        <!-- Header row -->
                        <HBox alignment="CENTER_LEFT" spacing="16">
                            <VBox HBox.hgrow="ALWAYS" spacing="4">
                                <Label text="👥 Gestion des Utilisateurs" styleClass="page-title"/>
                                <Label fx:id="userCountLabel" text="" styleClass="page-breadcrumb"/>
                            </VBox>
                            <Button text="＋  Nouvel utilisateur" styleClass="btn-add-user" onAction="#handleNewUser"/>
                        </HBox>

                        <!-- Search bar -->
                        <HBox styleClass="search-bar-box" spacing="10" alignment="CENTER_LEFT">
                            <padding><Insets top="12" left="16" right="16" bottom="12"/></padding>
                            <Label text="🔍" styleClass="search-icon"/>
                            <TextField fx:id="fieldSearch" promptText="Rechercher par nom, prénom ou email…"
                                       styleClass="search-field" HBox.hgrow="ALWAYS"
                                       onAction="#handleSearchUser"/>
                            <Button text="Rechercher" styleClass="btn-search" onAction="#handleSearchUser"/>
                        </HBox>

                        <!-- Users list as styled TableView -->
                        <VBox styleClass="users-table-card" spacing="0">
                            <TableView fx:id="usersTable" styleClass="users-tv" VBox.vgrow="ALWAYS">
                                <columns>
                                    <TableColumn fx:id="colUserAvatar" text="Utilisateur" prefWidth="260" sortable="false"/>
                                    <TableColumn fx:id="colUserEmail" text="Email" prefWidth="240" sortable="false"/>
                                    <TableColumn fx:id="colUserStatut" text="Statut" prefWidth="100" sortable="false"/>
                                    <TableColumn fx:id="colUserRoles" text="Rôle" prefWidth="130" sortable="false"/>
                                    <TableColumn fx:id="colUserActions" text="Actions" prefWidth="140" sortable="false"/>
                                </columns>
                                <placeholder>
                                    <VBox alignment="CENTER" spacing="12">
                                        <padding><Insets top="48" bottom="48"/></padding>
                                        <Label text="👤" style="-fx-font-size:36px;"/>
                                        <Label text="Aucun utilisateur trouvé" styleClass="empty-label"/>
                                    </VBox>
                                </placeholder>
                            </TableView>
                        </VBox>
                    </VBox>

                    <!-- ═══════ VUES LANGUES (conteneurs vides, chargés dynamiquement) ═══════ -->
                    <VBox fx:id="languesView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="niveauxView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="coursView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="userProgressView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>

                    <!-- ═══════ VUES TESTS (conteneurs vides, chargés dynamiquement) ═══════ -->
                    <VBox fx:id="testsView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="questionsView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="reponsesView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="passagesView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="etudiantsView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>

                    <!-- ═══════ GROUPES (gestion-groupe branch — inline table) ═══════ -->
                    <VBox fx:id="groupesView" visible="false" managed="false" spacing="24">
                        <StackPane VBox.vgrow="ALWAYS">
                            <VBox spacing="20">

                                <!-- Header -->
                                <HBox alignment="CENTER_LEFT" spacing="16">
                                    <VBox HBox.hgrow="ALWAYS" spacing="4">
                                        <Label text="Gestion des Groupes" styleClass="page-title"/>
                                        <Label text="Créez et gérez vos groupes d'apprentissage" styleClass="admin-page-subtitle"/>
                                    </VBox>
                                    <Button fx:id="btnAddGroup" text="+ Nouveau Groupe"
                                            styleClass="btn-add" onAction="#handleAddGroup"/>
                                </HBox>

                                <!-- Search bar -->
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <TextField fx:id="searchField" promptText="Rechercher un groupe..."
                                               HBox.hgrow="ALWAYS" styleClass="admin-search-field"/>
                                    <Button text="Rechercher" styleClass="btn-search" onAction="#handleSearch"/>
                                    <Button text="Réinitialiser" styleClass="btn-reset" onAction="#handleResetFilters"/>
                                </HBox>

                                <!-- Table card -->
                                <VBox styleClass="admin-table-card">
                                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="admin-table-header">
                                        <Label text="Liste des Groupes" styleClass="admin-table-title" HBox.hgrow="ALWAYS"/>
                                        <Label fx:id="lblResultCount" text="0 groupe(s)" styleClass="admin-result-count"/>
                                        <Button text="Actualiser" styleClass="admin-refresh-btn" onAction="#handleRefreshGroups"/>
                                    </HBox>

                                    <TableView fx:id="groupesTable" styleClass="admin-table" prefHeight="500">
                                        <columns>
                                            <TableColumn fx:id="colGroupeId" text="ID" prefWidth="60"/>
                                            <TableColumn fx:id="colGroupeNom" text="Nom du Groupe" prefWidth="200"/>
                                            <TableColumn fx:id="colGroupeDescription" text="Description" prefWidth="290"/>
                                            <TableColumn fx:id="colGroupeCapacite" text="Capacité" prefWidth="90"/>
                                            <TableColumn fx:id="colGroupeStatut" text="Statut" prefWidth="110"/>
                                            <TableColumn fx:id="colGroupeDate" text="Date Création" prefWidth="140"/>
                                            <TableColumn fx:id="colGroupeActions" text="Actions" prefWidth="200"/>
                                        </columns>
                                        <placeholder>
                                            <VBox alignment="CENTER" spacing="12" style="-fx-padding: 50;">
                                                <Label text="Aucun groupe trouvé" styleClass="admin-table-empty-title"/>
                                                <Label text="Créez votre premier groupe pour commencer" styleClass="admin-table-empty-sub"/>
                                            </VBox>
                                        </placeholder>
                                    </TableView>
                                </VBox>
                            </VBox>

                            <!-- Form overlay (modal) -->
                            <StackPane fx:id="groupFormOverlay" visible="false" managed="false"
                                       style="-fx-background-color: rgba(0,0,0,0.4); -fx-padding: 24;">
                                <StackPane fx:id="groupFormHost" maxWidth="640" style="-fx-background-color: transparent;"/>
                            </StackPane>
                        </StackPane>
                    </VBox>

                    <!-- ═══════ AUTRES VUES ═══════ -->
                    <VBox fx:id="sessionsView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="reservationsView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="objectifsView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>
                    <VBox fx:id="tachesView" visible="false" managed="false" VBox.vgrow="ALWAYS"/>

                    <!-- ═══════ PROFIL INLINE ═══════ -->
                    <VBox fx:id="profileView" visible="false" managed="false" spacing="32">

                        <!-- Hero banner -->
                        <HBox styleClass="profile-hero-card" spacing="28" alignment="CENTER_LEFT">
                            <padding><Insets top="28" left="32" right="32" bottom="28"/></padding>
                            <StackPane styleClass="profile-hero-avatar">
                                <Label fx:id="heroInitials" text="??" styleClass="hero-initials"/>
                            </StackPane>
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label fx:id="heroFullName" text="Prénom Nom" styleClass="hero-name"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label fx:id="heroRoleBadge" text="Utilisateur" styleClass="hero-role-chip"/>
                                    <Label fx:id="heroStatusBadge" text="actif" styleClass="hero-status-chip hero-status-actif"/>
                                </HBox>
                                <Label fx:id="heroEmail" text="email@exemple.com" styleClass="hero-email"/>
                            </VBox>
                            <VBox spacing="4" alignment="CENTER_RIGHT">
                                <Label text="ID" styleClass="id-label-small"/>
                                <Label fx:id="heroId" text="#0" styleClass="id-value"/>
                            </VBox>
                        </HBox>

                        <!-- Form cards row -->
                        <HBox spacing="24">

                            <!-- Personal info card -->
                            <VBox styleClass="profile-form-card" spacing="20" HBox.hgrow="ALWAYS">
                                <padding><Insets top="28" left="28" right="28" bottom="28"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Informations personnelles" styleClass="form-card-title"/>
                                </HBox>
                                <Separator/>

                                <VBox spacing="6">
                                    <Label text="Prénom" styleClass="pf-label"/>
                                    <TextField fx:id="fieldPrenom" promptText="Prénom" styleClass="pf-field"/>
                                </VBox>
                                <VBox spacing="6">
                                    <Label text="Nom" styleClass="pf-label"/>
                                    <TextField fx:id="fieldNom" promptText="Nom" styleClass="pf-field"/>
                                </VBox>
                                <VBox spacing="6">
                                    <Label text="Email" styleClass="pf-label"/>
                                    <TextField fx:id="fieldEmail" promptText="email@exemple.com" styleClass="pf-field"/>
                                </VBox>

                                <!-- Statut + Rôle -->
                                <HBox fx:id="statusRoleRow" spacing="16">
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Statut" styleClass="pf-label"/>
                                        <ComboBox fx:id="comboStatut" styleClass="pf-combo" maxWidth="Infinity">
                                            <items>
                                                <javafx.collections.FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="actif"/>
                                                    <String fx:value="inactif"/>
                                                    <String fx:value="suspendu"/>
                                                    <String fx:value="online"/>
                                                    <String fx:value="offline"/>
                                                    <String fx:value="disabled"/>
                                                </javafx.collections.FXCollections>
                                            </items>
                                        </ComboBox>
                                    </VBox>
                                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                                        <Label text="Rôle" styleClass="pf-label"/>
                                        <ComboBox fx:id="comboRole" styleClass="pf-combo" maxWidth="Infinity">
                                            <items>
                                                <javafx.collections.FXCollections fx:factory="observableArrayList">
                                                    <String fx:value="Étudiant"/>
                                                    <String fx:value="Professeur"/>
                                                    <String fx:value="Administrateur"/>
                                                </javafx.collections.FXCollections>
                                            </items>
                                        </ComboBox>
                                    </VBox>
                                </HBox>
                            </VBox>

                            <!-- Password card -->
                            <VBox styleClass="profile-form-card" spacing="20" prefWidth="320">
                                <padding><Insets top="28" left="28" right="28" bottom="28"/></padding>
                                <HBox alignment="CENTER_LEFT" spacing="10">
                                    <Label text="Mot de passe" styleClass="form-card-title"/>
                                </HBox>
                                <Separator/>
                                <Label text="Laissez vide pour conserver le mot de passe actuel."
                                       styleClass="pf-hint" wrapText="true"/>
                                <VBox spacing="6">
                                    <Label text="Nouveau mot de passe" styleClass="pf-label"/>
                                    <PasswordField fx:id="fieldNewPassword" promptText="Min. 8 caractères" styleClass="pf-field"/>
                                </VBox>
                                <VBox spacing="6">
                                    <Label text="Confirmer le mot de passe" styleClass="pf-label"/>
                                    <PasswordField fx:id="fieldConfirmPassword" promptText="Confirmer" styleClass="pf-field"/>
                                </VBox>
                                <VBox spacing="4" fx:id="pwdStrengthBox" visible="false" managed="false">
                                    <Label fx:id="pwdStrengthLabel" text="" styleClass="pwd-strength-label"/>
                                    <HBox spacing="4">
                                        <Region fx:id="bar1" styleClass="pwd-bar" HBox.hgrow="ALWAYS"/>
                                        <Region fx:id="bar2" styleClass="pwd-bar" HBox.hgrow="ALWAYS"/>
                                        <Region fx:id="bar3" styleClass="pwd-bar" HBox.hgrow="ALWAYS"/>
                                        <Region fx:id="bar4" styleClass="pwd-bar" HBox.hgrow="ALWAYS"/>
                                    </HBox>
                                </VBox>
                            </VBox>
                        </HBox>

                        <Label fx:id="profileMessage" styleClass="profile-page-message"
                               visible="false" managed="false" wrapText="true"/>

                        <HBox spacing="14" alignment="CENTER_RIGHT">
                            <Button text="Annuler les modifications" styleClass="btn-pf-cancel" onAction="#handleProfileCancel"/>
                            <Button text="Enregistrer les modifications" styleClass="btn-pf-save" onAction="#handleProfileSave"/>
                        </HBox>
                    </VBox>

                </VBox>
            </ScrollPane>
        </VBox>
    </center>

</BorderPane>
